---
import BaseLayout from '../../layouts/BaseLayout.astro';
import CodeNav from '../../components/CodeNav.astro';
import Footer from '../../components/Footer.astro';

const base = import.meta.env.BASE_URL;
---

<BaseLayout
  title="Code Overview — IPS Pipeline"
  titleZh="代码概览 · IPS 流程"
  description="High-level overview of the IPS computation pipeline and its quality gates."
  descriptionZh="IPS 计算流程及其质量检查点的高层概览。"
>
  <CodeNav active="overview" />
  <main class="code-page">
    <div class="code-page-header">
      <span class="code-page-label" data-i18n-en="Code Understanding" data-i18n-zh="代码理解">Code Understanding</span>
      <h2 data-i18n-en="Pipeline Overview" data-i18n-zh="流程概览">Pipeline Overview</h2>
      <p
        data-i18n-en="High-level view of the IPS computational pipeline. Click expandable nodes to reveal quality gates."
        data-i18n-zh="IPS 计算流程的高层视图。点击可展开节点可查看关键质量检查点。"
      >High-level view of the IPS computational pipeline. Click expandable nodes to reveal quality gates.</p>
    </div>
    <div class="iframe-container">
      <iframe
        src={`${base}/code/overview.html`}
        title="IPS Pipeline Overview Flowchart"
        data-title-en="IPS Pipeline Overview Flowchart"
        data-title-zh="IPS 流程概览图"
        loading="lazy"
      ></iframe>
    </div>
  </main>
  <Footer />
</BaseLayout>

<style>
  .code-page {
    padding-top: 56px;
    min-height: 100vh;
  }

  .code-page-header {
    max-width: 800px;
    margin: 0 auto;
    padding: 3rem 1.5rem 1.5rem;
  }

  .code-page-label {
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--accent-cyan);
    font-weight: 600;
    display: block;
    margin-bottom: 0.5rem;
  }

  .code-page-header h2 {
    font-size: 2rem;
    margin-bottom: 0.5rem;
  }

  .code-page-header p {
    color: var(--text-secondary);
    font-size: 0.95rem;
  }

  .iframe-container {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 1.5rem 3rem;
  }

  .iframe-container iframe {
    width: 100%;
    height: 80vh;
    min-height: 600px;
    border: 1px solid rgba(255, 255, 255, 0.06);
    border-radius: 12px;
    background: #0A0E17;
  }
</style>
