---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import Math from '../components/Math.astro';
---

<BaseLayout>
  <Nav />

  <!-- ═══ Section 1: Hero ═══ -->
  <section id="hero" class="hero">
    <canvas id="hero-canvas"></canvas>
    <div class="hero-overlay">
      <div class="hero-content stagger">
        <p class="hero-tag"
          data-i18n-en="Interacting Particle Systems"
          data-i18n-zh="相互作用粒子系统">Interacting Particle Systems</p>
        <h1 class="hero-title">
          <span data-i18n-en="Learning from" data-i18n-zh="从">Learning from</span>
          <span class="hero-accent"
            data-i18n-en="Unlabeled Data"
            data-i18n-zh="无标签数据学习">Unlabeled Data</span>
        </h1>
        <p class="hero-authors">Viska Wei &amp; Fei Lu</p>
        <div class="hero-buttons">
          <a href="https://arxiv.org/abs/2604.02581" class="btn btn-outline">Paper PDF</a>
          <a href="https://github.com/ViskaWei/lips_unlabeled_data" class="btn btn-outline">Code</a>
          <a href="#insight" class="btn btn-outline"
            data-i18n-en="Explore"
            data-i18n-zh="探索">Explore</a>
        </div>
      </div>
    </div>
  </section>

  <!-- SDE Formula Card -->
  <div class="formula-card" style="max-width: 680px; margin: -2rem auto 0; position: relative; z-index: 10; background: rgba(15, 23, 42, 0.8); backdrop-filter: blur(12px); border: 1px solid rgba(255,255,255,0.08); border-radius: 12px; padding: 1.5rem 2rem; text-align: center;">
    <p style="font-size: 0.75rem; text-transform: uppercase; letter-spacing: 0.15em; color: var(--accent-cyan); margin-bottom: 0.75rem;"
      data-i18n-en="The Governing Equation"
      data-i18n-zh="控制方程">The Governing Equation</p>
    <div class="math-block" style="margin: 0;">
      <Math tex={String.raw`dX_t^i = \Big(-\nabla V(X_t^i) - \frac{1}{N}\sum_{j \neq i} \nabla\Phi(X_t^i - X_t^j)\Big) dt + \sigma\, dW_t^i`} />
    </div>
    <div style="display: flex; justify-content: center; gap: 2rem; margin-top: 1rem; flex-wrap: wrap; font-size: 0.8rem; color: var(--text-muted);">
      <span><span style="color: #3b82f6; font-weight: 600;">V</span>
        <span data-i18n-en=" = confinement (pulls each particle toward center)"
              data-i18n-zh=" = 束缚势（把每个粒子往中心拉）"> = confinement (pulls each particle toward center)</span></span>
      <span><span style="color: #8b5cf6; font-weight: 600;">&Phi;</span>
        <span data-i18n-en=" = interaction (between particles)"
              data-i18n-zh=" = 交互势（粒子间相互作用）"> = interaction (between particles)</span></span>
      <span><span style="color: #94a3b8; font-weight: 600;">&sigma;dW</span>
        <span data-i18n-en=" = random noise"
              data-i18n-zh=" = 随机噪声"> = random noise</span></span>
    </div>
    <p style="font-size: 0.85rem; color: var(--accent-cyan); margin-top: 0.75rem; margin-bottom: 0; font-weight: 500;"
      data-i18n-en="Goal: learn V and &Phi; from unlabeled snapshots — without knowing which particle is which"
      data-i18n-zh="目标：从无标签快照学习 V 和 &Phi; — 不知道哪个粒子是哪个">Goal: learn V and &Phi; from unlabeled snapshots — without knowing which particle is which</p>
  </div>

  <div class="section-divider"></div>

  <!-- ═══ Section 1b: What are V and Φ? ═══ -->
  <section id="forces" class="section section-wide">
    <p class="section-label"
      data-i18n-en="The Setup"
      data-i18n-zh="物理设定">The Setup</p>
    <h2 data-i18n-en="What are V and &Phi;?"
        data-i18n-zh="V 和 &Phi; 是什么？">What are V and &Phi;?</h2>
    <p data-i18n-en="Three particles under two forces. The blue arrows pull each particle toward the center (confinement V). The purple arrows push particles apart (interaction &Phi;). The gray arrows are random noise. The combined effect produces the complex motion you see."
       data-i18n-zh="三个粒子在两种力的作用下运动。蓝色箭头把每个粒子往中心拉（束缚势 V）。紫色箭头让粒子互相排斥（交互势 &Phi;）。灰色箭头是随机噪声。三种力的合力产生了你看到的复杂运动。">
      Three particles under two forces. The blue arrows pull each particle toward the center (confinement V). The purple arrows push particles apart (interaction &Phi;). The gray arrows are random noise. The combined effect produces the complex motion you see.
    </p>

    <div class="demo-container">
      <div class="demo-canvas-wrap" style="aspect-ratio: 16/9;">
        <canvas id="force-viz-canvas" style="min-height: 380px;"></canvas>
      </div>
    </div>

    <div class="callout callout-insight" style="margin-top: 1.5rem;">
      <p style="margin: 0;"
        data-i18n-en="We observe the particle positions, but we don't know V or &Phi;. Our goal: reverse-engineer these forces from the data alone."
        data-i18n-zh="我们能观测粒子的位置，但不知道 V 和 &Phi;。我们的目标：仅从数据反推这些力。">
        We observe the particle positions, but we don't know V or &Phi;. Our goal: reverse-engineer these forces from the data alone.
      </p>
    </div>
  </section>

  <div class="section-divider"></div>

  <!-- ═══ Section 2: The Problem ═══ -->
  <section id="problem" class="section section-wide">
    <p class="section-label"
      data-i18n-en="The Problem"
      data-i18n-zh="核心问题">The Problem</p>
    <h2 data-i18n-en="The Problem: Unlabeled Data"
        data-i18n-zh="问题：无标签数据">The Problem: Unlabeled Data</h2>
    <p data-i18n-en="Imagine photographing a flock of birds at two different times. Each snapshot shows where every bird is — but you can't tell which bird is which across photos. Even with just 4 particles, there are 4! = 24 possible matchings. In real experiments with N=100, that's 100! &approx; 10<sup>158</sup> — more than the atoms in the universe."
       data-i18n-zh="想象你在两个不同时间拍摄一群鸟。每张快照都显示了每只鸟的位置——但你无法分辨不同照片中哪只鸟是哪只。即使只有 4 个粒子，也有 4! = 24 种可能的匹配。在真实实验中 N=100，那就是 100! &approx; 10<sup>158</sup> — 比宇宙中的原子还多。">
      Imagine photographing a flock of birds at two different times. Each snapshot shows where every bird is — but you can't tell which bird is which across photos. Even with just 4 particles, there are 4! = 24 possible matchings. In real experiments with N=100, that's 100! &approx; 10<sup>158</sup> — more than the atoms in the universe.
    </p>

    <!-- Demo A: Label Toggle -->
    <div class="demo-container">
      <div class="demo-canvas-wrap">
        <canvas id="label-demo-canvas" style="min-height: 380px;"></canvas>
      </div>
      <div class="demo-controls">
        <div class="toggle-group">
          <button class="toggle-btn active" data-mode="labeled">Labeled</button>
          <button class="toggle-btn" data-mode="unlabeled">Unlabeled</button>
        </div>
        <span class="demo-hint" style="font-size: 0.8rem; color: var(--text-muted);"
          data-i18n-en="Toggle to see what information is lost"
          data-i18n-zh="切换查看信息丢失的效果">Toggle to see what information is lost</span>
      </div>
    </div>

    <!-- Demo B: Shuffle — shows why matching is hopeless -->
    <div class="demo-container" style="margin-top: 2rem;">
      <div class="demo-canvas-wrap" style="aspect-ratio: 2/1; min-height: 300px;">
        <canvas id="shuffle-demo-canvas"></canvas>
      </div>
      <div class="demo-controls">
        <button id="shuffle-btn" class="btn btn-outline"
          data-i18n-en="Shuffle Identities"
          data-i18n-zh="打乱身份">Shuffle Identities</button>
        <span class="demo-hint" style="font-size: 0.8rem; color: var(--text-muted);"
          data-i18n-en="Left: labeled snapshot. Right: same particles, unknown identity. Which matching is correct?"
          data-i18n-zh="左：有标签快照。右：同一批粒子，身份未知。哪个匹配是正确的？">Left: labeled snapshot. Right: same particles, unknown identity. Which matching is correct?</span>
      </div>
    </div>

    <div class="callout callout-insight" style="margin-top: 1.5rem;">
      <p style="margin: 0;"
        data-i18n-en="Without labels, we cannot match particles across snapshots — and we don't try to. Our method works directly with the empirical distribution, bypassing the N! combinatorial explosion entirely."
        data-i18n-zh="没有标签，我们无法跨快照匹配粒子——我们也不尝试。我们的方法直接处理经验分布，完全绕过 N! 组合爆炸。">
        Without labels, we cannot match particles across snapshots — and we don't try to. Our method works directly with the empirical distribution, bypassing the N! combinatorial explosion entirely.
      </p>
    </div>
  </section>

  <div class="section-divider"></div>

  <!-- ═══ Section 3: Why It's Hard ═══ -->
  <section id="challenge" class="section section-wide">
    <p class="section-label"
      data-i18n-en="The Challenge"
      data-i18n-zh="挑战">The Challenge</p>
    <h2 data-i18n-en="Why Existing Methods Fail"
        data-i18n-zh="现有方法为什么失败">Why Existing Methods Fail</h2>
    <p data-i18n-en="Traditional methods estimate velocity as v &approx; &Delta;X/&Delta;t. This creates two fatal problems: when &Delta;t is small, noise explodes (&prop; &sigma;/&radic;&Delta;t); when &Delta;t is large, discretization bias grows as O(&Delta;t) and Sinkhorn matching accuracy drops to random chance. Drag the slider to see the collapse:"
       data-i18n-zh="传统方法将速度估计为 v &approx; &Delta;X/&Delta;t。这造成两个致命问题：&Delta;t 小时噪声爆炸（&prop; &sigma;/&radic;&Delta;t）；&Delta;t 大时离散化偏差为 O(&Delta;t)，且 Sinkhorn 匹配精度降至随机水平。拖动滑块查看崩溃：">
      Traditional methods estimate velocity as v &approx; &Delta;X/&Delta;t. This creates two fatal problems: when &Delta;t is small, noise explodes (&prop; &sigma;/&radic;&Delta;t); when &Delta;t is large, discretization bias grows as O(&Delta;t) and Sinkhorn matching accuracy drops to random chance. Drag the slider to see the collapse:
    </p>

    <div class="demo-container">
      <div id="dt-slider-viz" style="padding: 1rem 2rem; min-height: 240px;">
        <!-- D3 chart injected here -->
      </div>
      <div class="demo-controls">
        <label style="font-size: 0.85rem; color: var(--text-secondary); display: flex; align-items: center; gap: 0.75rem;">
          <span>&Delta;t</span>
          <input type="range" id="dt-slider" min="0" max="3" step="1" value="2"
            style="width: 200px; accent-color: var(--accent-cyan);" />
          <span id="dt-value" style="font-family: var(--font-mono); min-width: 3.5em;">0.01</span>
        </label>
      </div>
    </div>

    <!-- Why each method fails — detailed explanation cards -->
    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; margin-top: 1.5rem;">
      <div style="padding: 1rem 1.25rem; background: rgba(148, 163, 184, 0.06); border-radius: 10px; border-left: 3px solid #94a3b8;">
        <p style="font-weight: 600; font-size: 0.9rem; color: #94a3b8; margin-bottom: 0.5rem;"
          data-i18n-en="Labeled MLE: Noise Explosion"
          data-i18n-zh="标签 MLE：噪声爆炸">Labeled MLE: Noise Explosion</p>
        <p style="font-size: 0.8rem; color: var(--text-muted); margin-bottom: 0.5rem;"
          data-i18n-en="Estimates velocity as v &approx; &Delta;X/&Delta;t. When &Delta;t &rarr; 0, noise &prop; &sigma;/&radic;&Delta;t &rarr; &infin;. When &Delta;t is large, O(&Delta;t) discretization bias accumulates over N&minus;1 interaction terms."
          data-i18n-zh="将速度估计为 v &approx; &Delta;X/&Delta;t。当 &Delta;t &rarr; 0 时，噪声 &prop; &sigma;/&radic;&Delta;t &rarr; &infin;。当 &Delta;t 大时，O(&Delta;t) 离散化偏差在 N&minus;1 个交互项上累积。">
          Estimates velocity as v &approx; &Delta;X/&Delta;t. When &Delta;t &rarr; 0, noise &prop; &sigma;/&radic;&Delta;t &rarr; &infin;. When &Delta;t is large, O(&Delta;t) discretization bias accumulates over N&minus;1 interaction terms.
        </p>
        <p style="font-size: 0.8rem; font-family: var(--font-mono); color: #ef4444; margin: 0;"
          data-i18n-en="&nabla;V: 0.8% &rarr; 11.3% as &Delta;t grows"
          data-i18n-zh="&nabla;V: 0.8% &rarr; 11.3% 随 &Delta;t 增大">&nabla;V: 0.8% &rarr; 11.3% as &Delta;t grows</p>
      </div>
      <div style="padding: 1rem 1.25rem; background: rgba(167, 139, 250, 0.06); border-radius: 10px; border-left: 3px solid #a78bfa;">
        <p style="font-weight: 600; font-size: 0.9rem; color: #a78bfa; margin-bottom: 0.5rem;"
          data-i18n-en="Sinkhorn MLE: Matching Collapse"
          data-i18n-zh="Sinkhorn MLE：匹配崩溃">Sinkhorn MLE: Matching Collapse</p>
        <p style="font-size: 0.8rem; color: var(--text-muted); margin-bottom: 0.5rem;"
          data-i18n-en="Uses optimal transport to guess which particle is which. At small &Delta;t, works well (particles barely move). At large &Delta;t, particles mix completely — matching accuracy drops to 24.5%, near the 10% random baseline."
          data-i18n-zh="用最优传输猜测哪个粒子是哪个。&Delta;t 小时效果好（粒子几乎不动）。&Delta;t 大时，粒子完全混合——匹配精度降至 24.5%，接近 10% 随机基线。">
          Uses optimal transport to guess which particle is which. At small &Delta;t, works well (particles barely move). At large &Delta;t, particles mix completely — matching accuracy drops to 24.5%, near the 10% random baseline.
        </p>
        <p style="font-size: 0.8rem; font-family: var(--font-mono); color: #ef4444; margin: 0;"
          data-i18n-en="&nabla;&Phi;: 0.8% &rarr; 95.8% as &Delta;t grows"
          data-i18n-zh="&nabla;&Phi;: 0.8% &rarr; 95.8% 随 &Delta;t 增大">&nabla;&Phi;: 0.8% &rarr; 95.8% as &Delta;t grows</p>
      </div>
    </div>

    <div style="text-align: center; margin-top: 1rem; padding: 0.75rem; background: rgba(34, 197, 94, 0.06); border-radius: 8px; border: 1px solid rgba(34, 197, 94, 0.15);">
      <p style="margin: 0; font-size: 0.85rem; color: #22c55e; font-weight: 600;"
        data-i18n-en="Our self-test avoids both pitfalls: no velocity estimation, no trajectory matching"
        data-i18n-zh="我们的自测同时避开了两个陷阱：无需速度估计，无需轨迹匹配">
        Our self-test avoids both pitfalls: no velocity estimation, no trajectory matching
      </p>
      <p style="margin: 0.25rem 0 0; font-size: 0.8rem; font-family: var(--font-mono); color: var(--text-muted);"
        data-i18n-en="Self-Test &nabla;V: 0.67% &rarr; 6.84% (7&times; more robust than Sinkhorn at large &Delta;t)"
        data-i18n-zh="自测 &nabla;V: 0.67% &rarr; 6.84%（大 &Delta;t 下比 Sinkhorn 鲁棒 7 倍）">
        Self-Test &nabla;V: 0.67% &rarr; 6.84% (7&times; more robust than Sinkhorn at large &Delta;t)
      </p>
    </div>
  </section>

  <div class="section-divider"></div>

  <!-- ═══ Section 4: Our Approach — The Weak Form PDE ═══ -->
  <section id="insight" class="section section-wide">
    <p class="section-label"
      data-i18n-en="Our Approach"
      data-i18n-zh="我们的方法">Our Approach</p>
    <h2 data-i18n-en="From Particles to Distributions: The Weak Form PDE"
        data-i18n-zh="从粒子到分布：弱形式 PDE">From Particles to Distributions: The Weak Form PDE</h2>

    <!-- Step 1: The key realization -->
    <div class="callout callout-insight" style="margin-bottom: 2rem; border-left: 3px solid var(--accent-cyan);">
      <p style="margin: 0; font-size: 0.95rem;"
        data-i18n-en="Key realization: we don't need to track individual particles. The empirical distribution &mu;&#8346; = (1/N)&sum;&delta;(X&#7522;) is directly observable from unlabeled snapshots — no labels needed. Better yet, &mu;&#8346; satisfies a PDE that is linear in V and &Phi;. This transforms the N! combinatorial matching problem into a functional optimization."
        data-i18n-zh="关键洞察：我们不需要追踪单个粒子。经验分布 &mu;&#8346; = (1/N)&sum;&delta;(X&#7522;) 可以从无标签快照直接观测——不需要标签。更好的是，&mu;&#8346; 满足一个关于 V 和 &Phi; 线性的 PDE。这将 N! 组合匹配问题转化为泛函优化。">
        Key realization: we don't need to track individual particles. The empirical distribution &mu;&#8346; = (1/N)&sum;&delta;(X&#7522;) is directly observable from unlabeled snapshots — no labels needed. Better yet, &mu;&#8346; satisfies a PDE that is linear in V and &Phi;. This transforms the N! combinatorial matching problem into a functional optimization.
      </p>
    </div>

    <!-- Step 2: Why the Weak Form? -->
    <h3 data-i18n-en="Why the Weak Form?"
        data-i18n-zh="为什么用弱形式？">Why the Weak Form?</h3>
    <p data-i18n-en="The particle distribution &mu;&#8346; evolves according to a Fokker-Planck-type PDE. But &mu;&#8346; is a sum of delta functions — we can't take its derivatives directly. The weak form solves this: multiply the PDE by a smooth test function &psi; and integrate. Now everything becomes empirical averages over particle positions — directly computable from snapshots, with no derivatives of &mu;&#8346; needed."
       data-i18n-zh="粒子分布 &mu;&#8346; 按 Fokker-Planck 型 PDE 演化。但 &mu;&#8346; 是 delta 函数之和——无法直接求导。弱形式解决了这个问题：将 PDE 乘以光滑测试函数 &psi; 并积分。现在一切都变成了粒子位置的经验平均——直接从快照计算，无需对 &mu;&#8346; 求导。">
      The particle distribution &mu;&#8346; evolves according to a Fokker-Planck-type PDE. But &mu;&#8346; is a sum of delta functions — we can't take its derivatives directly. The weak form solves this: multiply the PDE by a smooth test function &psi; and integrate. Now everything becomes empirical averages over particle positions — directly computable from snapshots, with no derivatives of &mu;&#8346; needed.
    </p>

    <div style="display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 1rem; margin: 1.5rem 0;">
      <div style="text-align: center; padding: 1rem; background: rgba(239, 68, 68, 0.06); border-radius: 10px; border-top: 3px solid #ef4444;">
        <p style="font-size: 0.75rem; text-transform: uppercase; letter-spacing: 0.1em; color: #ef4444; margin-bottom: 0.5rem;"
          data-i18n-en="Strong Form"
          data-i18n-zh="强形式">Strong Form</p>
        <p style="font-size: 0.85rem; color: var(--text-muted); margin: 0;"
          data-i18n-en="Requires &nabla;&mu; — impossible for delta functions"
          data-i18n-zh="需要 &nabla;&mu; — 对 delta 函数不可能">Requires &nabla;&mu; — impossible for delta functions</p>
      </div>
      <div style="text-align: center; padding: 1rem; background: rgba(34, 197, 94, 0.06); border-radius: 10px; border-top: 3px solid #22c55e;">
        <p style="font-size: 0.75rem; text-transform: uppercase; letter-spacing: 0.1em; color: #22c55e; margin-bottom: 0.5rem;"
          data-i18n-en="Weak Form"
          data-i18n-zh="弱形式">Weak Form</p>
        <p style="font-size: 0.85rem; color: var(--text-muted); margin: 0;"
          data-i18n-en="Only needs &int;&psi; d&mu; = (1/N)&sum;&psi;(X&#7522;) — computable!"
          data-i18n-zh="只需 &int;&psi; d&mu; = (1/N)&sum;&psi;(X&#7522;) — 可计算！">Only needs &int;&psi; d&mu; = (1/N)&sum;&psi;(X&#7522;) — computable!</p>
      </div>
      <div style="text-align: center; padding: 1rem; background: rgba(59, 130, 246, 0.06); border-radius: 10px; border-top: 3px solid #3b82f6;">
        <p style="font-size: 0.75rem; text-transform: uppercase; letter-spacing: 0.1em; color: #3b82f6; margin-bottom: 0.5rem;"
          data-i18n-en="Key Property"
          data-i18n-zh="关键性质">Key Property</p>
        <p style="font-size: 0.85rem; color: var(--text-muted); margin: 0;"
          data-i18n-en="Linear in V and &Phi; &rarr; convex optimization"
          data-i18n-zh="关于 V 和 &Phi; 线性 &rarr; 凸优化">Linear in V and &Phi; &rarr; convex optimization</p>
      </div>
    </div>

    <p data-i18n-en="The crucial advantage: because the weak form PDE is linear in V and &Phi;, we can choose the test function &psi; to be V and &Phi; themselves. This self-testing trick — using the unknowns as their own test functions — produces a loss with a remarkable property."
       data-i18n-zh="关键优势：由于弱形式 PDE 关于 V 和 &Phi; 是线性的，我们可以选择测试函数 &psi; 就是 V 和 &Phi; 本身。这个自测技巧——用未知量作为自己的测试函数——产生了一个具有显著性质的损失函数。">
      The crucial advantage: because the weak form PDE is linear in V and &Phi;, we can choose the test function &psi; to be V and &Phi; themselves. This self-testing trick — using the unknowns as their own test functions — produces a loss with a remarkable property.
    </p>

    <!-- Step 3: The Self-Test Loss -->
    <h3 style="margin-top: 2.5rem;"
      data-i18n-en="The Self-Test Loss"
      data-i18n-zh="自测损失函数">The Self-Test Loss</h3>
    <p data-i18n-en="Applying Ito's formula with &psi; = V + &Phi;*&mu; (the energy functional) as the test function, the weak form residual decomposes into three computable terms. Each term is an empirical average over particle snapshots — no velocity estimation, no trajectory matching."
       data-i18n-zh="以 &psi; = V + &Phi;*&mu;（能量泛函）作为测试函数应用伊藤公式，弱形式残差分解为三个可计算项。每一项都是粒子快照上的经验平均——无需速度估计，无需轨迹匹配。">
      Applying Ito's formula with &psi; = V + &Phi;*&mu; (the energy functional) as the test function, the weak form residual decomposes into three computable terms. Each term is an empirical average over particle snapshots — no velocity estimation, no trajectory matching.
    </p>

    <div class="math-block">
      <Math tex={String.raw`\mathcal{L}(\theta) = \frac{1}{2}\, J_{\text{diss}}\, \Delta t \;-\; \frac{\sigma^2}{2}\, J_{\text{diff}}\, \Delta t \;+\; \delta E_{\text{tot}}`} />
    </div>

    <!-- Loss Anatomy -->
    <h3 style="margin-top: 2.5rem;"
      data-i18n-en="Anatomy of the Loss"
      data-i18n-zh="损失函数解剖">Anatomy of the Loss</h3>
    <p data-i18n-en="Each term comes from the weak form PDE tested against the energy functional:"
       data-i18n-zh="每一项来自以能量泛函为测试函数的弱形式 PDE：">
      Each term comes from the weak form PDE tested against the energy functional:
    </p>

    <div class="loss-anatomy">
      <div class="loss-anatomy-header">
        <div class="math-block" style="margin: 0; border-left-color: var(--accent-cyan);">
          <Math tex={String.raw`\mathcal{L} = \underbrace{\tfrac{1}{2}\, J_{\text{diss}}\, \Delta t}_{\color{#ef4444}\text{dissipation}} \;-\; \underbrace{\tfrac{\sigma^2}{2}\, J_{\text{diff}}\, \Delta t}_{\color{#3b82f6}\text{diffusion}} \;+\; \underbrace{\delta E_{\text{tot}}}_{\color{#f59e0b}\text{energy change}}`} />
        </div>
      </div>

      <div class="loss-component">
        <div class="lc-color" style="background: #ef4444;"></div>
        <div class="lc-body">
          <h4 style="color: #ef4444;">
            J<sub>diss</sub> = &Sigma;&Vert;drift&Vert;&sup2; / N
          </h4>
          <p data-i18n-en="Dissipation: how much work the drift forces do. The 1/2 coefficient (from the self-test trick) is what breaks the degeneracy — it makes L(V*, &Phi;*) strictly negative."
             data-i18n-zh="耗散：漂移力做了多少功。1/2 系数（来自自测技巧）是打破退化的关键——它使 L(V*, &Phi;*) 严格为负。">
            Dissipation: how much work the drift forces do. The 1/2 coefficient (from the self-test trick) is what breaks the degeneracy — it makes L(V*, &Phi;*) strictly negative.
          </p>
        </div>
      </div>

      <div class="loss-component">
        <div class="lc-color" style="background: #3b82f6;"></div>
        <div class="lc-body">
          <h4 style="color: #3b82f6;">
            J<sub>diff</sub> = (1/N) &Sigma;<sub>i</sub>&Delta;V + (1/N&sup2;) &Sigma;<sub>i&ne;j</sub>&Delta;&Phi;
          </h4>
          <p data-i18n-en="Diffusion contribution: depends on the Laplacian of V and &Phi;. Computable from snapshots via the basis expansion or neural network parameterization."
             data-i18n-zh="扩散贡献：取决于 V 和 &Phi; 的拉普拉斯量。通过基函数展开或神经网络参数化可从快照计算。">
            Diffusion contribution: depends on the Laplacian of V and &Phi;. Computable from snapshots via the basis expansion or neural network parameterization.
          </p>
        </div>
      </div>

      <div class="loss-component">
        <div class="lc-color" style="background: #f59e0b;"></div>
        <div class="lc-body">
          <h4 style="color: #f59e0b;">
            &delta;E<sub>tot</sub> = E(t+&Delta;t) &minus; E(t)
          </h4>
          <p data-i18n-en="Energy change between two snapshots. Directly observable from unlabeled data — no trajectory information needed!"
             data-i18n-zh="两个快照之间的能量变化。可直接从无标签数据观测——无需轨迹信息！">
            Energy change between two snapshots. Directly observable from unlabeled data — no trajectory information needed!
          </p>
        </div>
      </div>

      <div class="loss-anatomy-footer">
        <div class="math-block" style="margin: 0 0 0.5rem; padding: 0.75rem; background: transparent; border-left-color: var(--accent-green);">
          <Math tex={String.raw`\mathbb{E}[\mathcal{L}(V^*, \Phi^*)] = -\tfrac{1}{2}\,\mathbb{E}[J_{\text{diss}}^*\,\Delta t] < 0 \qquad \text{vs.} \qquad \mathcal{L}(0, 0) = 0`} />
        </div>
        <p style="margin: 0; color: #22c55e; font-size: 0.85rem;"
          data-i18n-en="The true potentials produce a strictly negative loss, while the trivial solution gives zero — this breaks the degeneracy that plagues squared-residual approaches."
          data-i18n-zh="真实势函数产生严格负的损失值，而平凡解给出零——这打破了困扰平方残差方法的退化性。">
          The true potentials produce a strictly negative loss, while the trivial solution gives zero — this breaks the degeneracy that plagues squared-residual approaches.
        </p>
      </div>
    </div>

    <!-- Loss Landscape -->
    <h3 style="margin-top: 3rem;"
      data-i18n-en="Why Not Just Square the Residual?"
      data-i18n-zh="为什么不直接对残差取平方？">Why Not Just Square the Residual?</h3>
    <p data-i18n-en="Squaring the weak form residual creates a degenerate minimum at V=0, &Phi;=0 (the trivial solution). Our self-test loss, by using V and &Phi; as their own test functions, has a strictly negative minimum at the true potentials."
       data-i18n-zh="对弱形式残差取平方会在V=0, &Phi;=0处产生退化极小值（平凡解）。我们的自测损失通过用 V 和 &Phi; 作为自己的测试函数，在真实势函数处具有严格负的极小值。">
      Squaring the weak form residual creates a degenerate minimum at V=0, &Phi;=0 (the trivial solution). Our self-test loss, by using V and &Phi; as their own test functions, has a strictly negative minimum at the true potentials.
    </p>

    <div class="demo-container">
      <div class="demo-canvas-wrap" style="aspect-ratio: 2/1;">
        <canvas id="loss-landscape-canvas"></canvas>
      </div>
    </div>

    <!-- Why Not Energy Balance? -->
    <h3 style="margin-top: 3rem;"
      data-i18n-en="Why Not Energy Balance?"
      data-i18n-zh="为什么不用能量平衡？">Why Not Energy Balance?</h3>
    <p data-i18n-en="You might wonder: since the system conserves energy, couldn't we just match the dissipation and diffusion terms directly? This is mathematically valid — for the true potentials, the energy identity does hold. But there's a fatal problem: using this for parameter estimation requires matching |&nabla;V|&sup2; and |&nabla;&Phi;|&sup2; terms, which are 4th-order in the potentials. The resulting optimization landscape is non-convex and computationally intractable."
       data-i18n-zh="你可能会想：既然系统守恒能量，能不能直接匹配耗散和扩散项？这在数学上是成立的——对于真实势函数，能量恒等式确实成立。但有一个致命问题：用此方法做参数估计需要匹配 |&nabla;V|&sup2; 和 |&nabla;&Phi;|&sup2; 项，这些是势函数的4次方。得到的优化问题是非凸的，计算上不可解。">
      You might wonder: since the system conserves energy, couldn't we just match the dissipation and diffusion terms directly? This is mathematically valid — for the true potentials, the energy identity does hold. But there's a fatal problem: using this for parameter estimation requires matching |&nabla;V|&sup2; and |&nabla;&Phi;|&sup2; terms, which are 4th-order in the potentials. The resulting optimization landscape is non-convex and computationally intractable.
    </p>

    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; margin: 1.5rem 0;">
      <div style="padding: 1rem 1.25rem; background: rgba(239, 68, 68, 0.06); border-radius: 10px; border-left: 3px solid #ef4444;">
        <p style="font-weight: 600; font-size: 0.9rem; color: #ef4444; margin-bottom: 0.5rem;"
          data-i18n-en="Energy Balance Approach"
          data-i18n-zh="能量平衡方法">Energy Balance Approach</p>
        <p style="font-size: 0.8rem; color: var(--text-muted); margin: 0;"
          data-i18n-en="Match dissipation = diffusion &minus; &delta;E. Involves |&nabla;V|&sup2; and |&nabla;&Phi;|&sup2; &rarr; 4th-order equations. Non-convex, intractable."
          data-i18n-zh="匹配 耗散 = 扩散 &minus; &delta;E。涉及 |&nabla;V|&sup2; 和 |&nabla;&Phi;|&sup2; &rarr; 4次方程。非凸，不可解。">
          Match dissipation = diffusion &minus; &delta;E. Involves |&nabla;V|&sup2; and |&nabla;&Phi;|&sup2; &rarr; 4th-order equations. Non-convex, intractable.
        </p>
      </div>
      <div style="padding: 1rem 1.25rem; background: rgba(34, 197, 94, 0.06); border-radius: 10px; border-left: 3px solid #22c55e;">
        <p style="font-weight: 600; font-size: 0.9rem; color: #22c55e; margin-bottom: 0.5rem;"
          data-i18n-en="Our Self-Test (Variation Approach)"
          data-i18n-zh="我们的自测（变分方法）">Our Self-Test (Variation Approach)</p>
        <p style="font-size: 0.8rem; color: var(--text-muted); margin: 0;"
          data-i18n-en="Test the weak form PDE against &psi; = V + &Phi;*&mu;. Only 2nd-order terms. Linear in basis coefficients &rarr; convex, solvable."
          data-i18n-zh="以 &psi; = V + &Phi;*&mu; 测试弱形式 PDE。只有2阶项。关于基函数系数线性 &rarr; 凸，可解。">
          Test the weak form PDE against &psi; = V + &Phi;*&mu;. Only 2nd-order terms. Linear in basis coefficients &rarr; convex, solvable.
        </p>
      </div>
    </div>

    <p style="font-size: 0.85rem; color: var(--text-muted);"
      data-i18n-en="The demo below illustrates the energy identity: when V and &Phi; are correct (both scales = 1), the three terms cancel. But turning this into an estimator would require 4th-order optimization — our self-test achieves the same goal with only 2nd-order terms."
      data-i18n-zh="下面的演示展示了能量恒等式：当 V 和 &Phi; 正确时（两个缩放均为1），三项相互抵消。但将此变为估计器需要4阶优化——我们的自测用2阶项达到了相同目标。">
      The demo below illustrates the energy identity: when V and &Phi; are correct (both scales = 1), the three terms cancel. But turning this into an estimator would require 4th-order optimization — our self-test achieves the same goal with only 2nd-order terms.
    </p>

    <!-- Energy Balance Demo — now contextualized as illustration of the failed alternative -->
    <div class="demo-container">
      <div class="demo-canvas-wrap" style="aspect-ratio: 16/9; min-height: 380px;">
        <canvas id="energy-canvas"></canvas>
      </div>
      <div class="demo-controls" style="flex-direction: column; align-items: stretch; gap: 0.75rem;">
        <div style="display: flex; gap: 1.5rem; flex-wrap: wrap;">
          <label style="flex: 1; min-width: 200px;">
            <span style="font-size: 0.8rem; color: var(--text-muted);"
              data-i18n-en="V scale (confinement strength)"
              data-i18n-zh="V缩放（束缚强度）">V scale (confinement strength)</span>
            <input type="range" id="v-scale" min="0" max="3" step="0.1" value="1"
              style="width: 100%; accent-color: var(--accent-blue);" />
          </label>
          <label style="flex: 1; min-width: 200px;">
            <span style="font-size: 0.8rem; color: var(--text-muted);"
              data-i18n-en="&Phi; scale (interaction strength)"
              data-i18n-zh="&Phi;缩放（交互强度）">&Phi; scale (interaction strength)</span>
            <input type="range" id="phi-scale" min="0" max="3" step="0.1" value="1"
              style="width: 100%; accent-color: var(--accent-purple);" />
          </label>
        </div>
      </div>
    </div>
  </section>

