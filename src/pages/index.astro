---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import Math from '../components/Math.astro';
---

<BaseLayout>
  <Nav />

  <!-- ═══ Section 1: Hero ═══ -->
  <section id="hero" class="hero">
    <canvas id="hero-canvas"></canvas>
    <div class="hero-overlay">
      <div class="hero-content stagger">
        <p class="hero-tag"
          data-i18n-en="Interacting Particle Systems"
          data-i18n-zh="相互作用粒子系统">Interacting Particle Systems</p>
        <h1 class="hero-title">
          <span data-i18n-en="Learning from" data-i18n-zh="从">Learning from</span>
          <span class="hero-accent"
            data-i18n-en="Unlabeled Data"
            data-i18n-zh="无标签数据学习">Unlabeled Data</span>
        </h1>
        <p class="hero-authors">Viska Wei &amp; Fei Lu</p>
        <div class="hero-buttons">
          <a href="https://arxiv.org/abs/2604.02581" class="btn btn-outline" data-i18n-en="Paper PDF" data-i18n-zh="论文 PDF">Paper PDF</a>
          <a href="https://github.com/ViskaWei/lips_unlabeled_data" class="btn btn-outline" data-i18n-en="Code" data-i18n-zh="代码">Code</a>
          <a href="#insight" class="btn btn-outline"
            data-i18n-en="Explore"
            data-i18n-zh="探索">Explore</a>
        </div>
      </div>
    </div>
  </section>

  <!-- SDE Formula Card -->
  <div class="formula-card" style="max-width: 680px; margin: -2rem auto 0; position: relative; z-index: 10; background: rgba(15, 23, 42, 0.8); backdrop-filter: blur(12px); border: 1px solid rgba(255,255,255,0.08); border-radius: 12px; padding: 1.5rem 2rem; text-align: center;">
    <p style="font-size: 0.75rem; text-transform: uppercase; letter-spacing: 0.15em; color: var(--accent-cyan); margin-bottom: 0.75rem;"
      data-i18n-en="The Governing Equation"
      data-i18n-zh="控制方程">The Governing Equation</p>
    <div class="math-block" style="margin: 0;">
      <Math tex={String.raw`dX_t^i = \Big(-\nabla V(X_t^i) - \frac{1}{N}\sum_{j \neq i} \nabla\Phi(X_t^i - X_t^j)\Big) dt + \sigma\, dW_t^i`} />
    </div>
    <div style="display: flex; justify-content: center; gap: 2rem; margin-top: 1rem; flex-wrap: wrap; font-size: 0.8rem; color: var(--text-muted);">
      <span><span style="color: #3b82f6; font-weight: 600;">V</span>
        <span data-i18n-en=" = confinement (pulls each particle toward center)"
              data-i18n-zh=" = 束缚势（把每个粒子往中心拉）"> = confinement (pulls each particle toward center)</span></span>
      <span><span style="color: #8b5cf6; font-weight: 600;">&Phi;</span>
        <span data-i18n-en=" = interaction (between particles)"
              data-i18n-zh=" = 交互势（粒子间相互作用）"> = interaction (between particles)</span></span>
      <span><span style="color: #94a3b8; font-weight: 600;">&sigma;dW</span>
        <span data-i18n-en=" = random noise"
              data-i18n-zh=" = 随机噪声"> = random noise</span></span>
    </div>
    <p style="font-size: 0.85rem; color: var(--accent-cyan); margin-top: 0.75rem; margin-bottom: 0; font-weight: 500;"
      data-i18n-en="Goal: learn V and &Phi; from unlabeled snapshots — without knowing which particle is which"
      data-i18n-zh="目标：从无标签快照学习 V 和 &Phi; — 不知道哪个粒子是哪个">Goal: learn V and &Phi; from unlabeled snapshots — without knowing which particle is which</p>
  </div>

  <div class="section-divider"></div>

  <!-- ═══ Section 1b: What are V and Φ? ═══ -->
  <section id="forces" class="section section-wide">
    <p class="section-label"
      data-i18n-en="The Setup"
      data-i18n-zh="物理设定">The Setup</p>
    <h2 data-i18n-en="What are V and &Phi;?"
        data-i18n-zh="V 和 &Phi; 是什么？">What are V and &Phi;?</h2>
    <p data-i18n-en="Three particles under two forces. The blue arrows pull each particle toward the center (confinement V). The purple arrows push particles apart (interaction &Phi;). The gray arrows are random noise. The combined effect produces the complex motion you see."
       data-i18n-zh="三个粒子在两种力的作用下运动。蓝色箭头把每个粒子往中心拉（束缚势 V）。紫色箭头让粒子互相排斥（交互势 &Phi;）。灰色箭头是随机噪声。三种力的合力产生了你看到的复杂运动。">
      Three particles under two forces. The blue arrows pull each particle toward the center (confinement V). The purple arrows push particles apart (interaction &Phi;). The gray arrows are random noise. The combined effect produces the complex motion you see.
    </p>

    <div class="demo-container">
      <div class="demo-canvas-wrap" style="aspect-ratio: 16/9;">
        <canvas id="force-viz-canvas" style="min-height: 380px;"></canvas>
      </div>
    </div>

    <div class="callout callout-insight" style="margin-top: 1.5rem;">
      <p style="margin: 0;"
        data-i18n-en="We observe the particle positions, but we don't know V or &Phi;. Our goal: reverse-engineer these forces from the data alone."
        data-i18n-zh="我们能观测粒子的位置，但不知道 V 和 &Phi;。我们的目标：仅从数据反推这些力。">
        We observe the particle positions, but we don't know V or &Phi;. Our goal: reverse-engineer these forces from the data alone.
      </p>
    </div>
  </section>

  <div class="section-divider"></div>

  <!-- ═══ Section 2: The Problem ═══ -->
  <section id="problem" class="section section-wide">
    <p class="section-label"
      data-i18n-en="The Problem"
      data-i18n-zh="核心问题">The Problem</p>
    <h2 data-i18n-en="The Problem: Unlabeled Data"
        data-i18n-zh="问题：无标签数据">The Problem: Unlabeled Data</h2>
    <p data-i18n-en="Imagine photographing a flock of birds at two different times. Each snapshot shows where every bird is — but you can't tell which bird is which across photos. Even with just 4 particles, there are 4! = 24 possible matchings. In real experiments with N=100, that's 100! &approx; 10<sup>158</sup> — more than the atoms in the universe."
       data-i18n-zh="想象你在两个不同时间拍摄一群鸟。每张快照都显示了每只鸟的位置——但你无法分辨不同照片中哪只鸟是哪只。即使只有 4 个粒子，也有 4! = 24 种可能的匹配。在真实实验中 N=100，那就是 100! &approx; 10<sup>158</sup> — 比宇宙中的原子还多。">
      Imagine photographing a flock of birds at two different times. Each snapshot shows where every bird is — but you can't tell which bird is which across photos. Even with just 4 particles, there are 4! = 24 possible matchings. In real experiments with N=100, that's 100! &approx; 10<sup>158</sup> — more than the atoms in the universe.
    </p>

    <!-- Demo A: Label Toggle -->
    <div class="demo-container">
      <div class="demo-canvas-wrap">
        <canvas id="label-demo-canvas" style="min-height: 380px;"></canvas>
      </div>
      <div class="demo-controls">
        <div class="toggle-group">
          <button class="toggle-btn active" data-mode="labeled" data-i18n-en="Labeled" data-i18n-zh="有标签">Labeled</button>
          <button class="toggle-btn" data-mode="unlabeled" data-i18n-en="Unlabeled" data-i18n-zh="无标签">Unlabeled</button>
        </div>
        <span class="demo-hint" style="font-size: 0.8rem; color: var(--text-muted);"
          data-i18n-en="Toggle to see what information is lost"
          data-i18n-zh="切换查看信息丢失的效果">Toggle to see what information is lost</span>
      </div>
    </div>

    <!-- Demo B: Shuffle — shows why matching is hopeless -->
    <div class="demo-container" style="margin-top: 2rem;">
      <div class="demo-canvas-wrap" style="aspect-ratio: 2/1; min-height: 300px;">
        <canvas id="shuffle-demo-canvas"></canvas>
      </div>
      <div class="demo-controls">
        <button id="shuffle-btn" class="btn btn-outline"
          data-i18n-en="Shuffle Identities"
          data-i18n-zh="打乱身份">Shuffle Identities</button>
        <span class="demo-hint" style="font-size: 0.8rem; color: var(--text-muted);"
          data-i18n-en="Left: labeled snapshot. Right: same particles, unknown identity. Which matching is correct?"
          data-i18n-zh="左：有标签快照。右：同一批粒子，身份未知。哪个匹配是正确的？">Left: labeled snapshot. Right: same particles, unknown identity. Which matching is correct?</span>
      </div>
    </div>

    <div class="callout callout-insight" style="margin-top: 1.5rem;">
      <p style="margin: 0;"
        data-i18n-en="Without labels, we cannot match particles across snapshots — and we don't try to. Our method works directly with the empirical distribution, bypassing the N! combinatorial explosion entirely."
        data-i18n-zh="没有标签，我们无法跨快照匹配粒子——我们也不尝试。我们的方法直接处理经验分布，完全绕过 N! 组合爆炸。">
        Without labels, we cannot match particles across snapshots — and we don't try to. Our method works directly with the empirical distribution, bypassing the N! combinatorial explosion entirely.
      </p>
    </div>
  </section>

  <div class="section-divider"></div>

  <!-- ═══ Section 3: Why It's Hard ═══ -->
  <section id="challenge" class="section section-wide">
    <p class="section-label"
      data-i18n-en="The Challenge"
      data-i18n-zh="挑战">The Challenge</p>
    <h2 data-i18n-en="Why Existing Methods Fail"
        data-i18n-zh="现有方法为什么失败">Why Existing Methods Fail</h2>
    <p data-i18n-en="Traditional methods estimate velocity as v &approx; &Delta;X/&Delta;t. This creates two fatal problems: when &Delta;t is small, noise explodes (&prop; &sigma;/&radic;&Delta;t); when &Delta;t is large, discretization bias grows as O(&Delta;t) and Sinkhorn matching accuracy drops to random chance. Drag the slider to see the collapse:"
       data-i18n-zh="传统方法将速度估计为 v &approx; &Delta;X/&Delta;t。这造成两个致命问题：&Delta;t 小时噪声爆炸（&prop; &sigma;/&radic;&Delta;t）；&Delta;t 大时离散化偏差为 O(&Delta;t)，且 Sinkhorn 匹配精度降至随机水平。拖动滑块查看崩溃：">
      Traditional methods estimate velocity as v &approx; &Delta;X/&Delta;t. This creates two fatal problems: when &Delta;t is small, noise explodes (&prop; &sigma;/&radic;&Delta;t); when &Delta;t is large, discretization bias grows as O(&Delta;t) and Sinkhorn matching accuracy drops to random chance. Drag the slider to see the collapse:
    </p>

    <p class="prediction-label" style="font-size:0.8rem;color:var(--accent-cyan);font-style:italic;margin-bottom:0.5rem;padding:0.5rem 0.75rem;background:rgba(79,156,249,0.06);border-radius:6px;border-left:3px solid var(--accent-cyan);"
      data-i18n-en="Prediction from §Solution: Self-test error is robust to large observation gaps Δt. Label-matching error explodes."
      data-i18n-zh="来自§解法的预测：自测误差对大观测时间步 Δt 鲁棒。标签匹配误差爆炸。">
      Prediction from &sect;Solution: Self-test error is robust to large observation gaps &Delta;t. Label-matching error explodes.
    </p>
    <div class="demo-container">
      <div id="dt-slider-viz" style="padding: 1rem 2rem; min-height: 240px;">
        <!-- D3 chart injected here -->
      </div>
      <div class="demo-controls">
        <label style="font-size: 0.85rem; color: var(--text-secondary); display: flex; align-items: center; gap: 0.75rem;">
          <span>&Delta;t</span>
          <input type="range" id="dt-slider" min="0" max="3" step="1" value="2"
            style="width: 200px; accent-color: var(--accent-cyan);" />
          <span id="dt-value" style="font-family: var(--font-mono); min-width: 3.5em;">0.01</span>
        </label>
      </div>
    </div>

    <!-- Why each method fails — detailed explanation cards -->
    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; margin-top: 1.5rem;">
      <div style="padding: 1rem 1.25rem; background: rgba(148, 163, 184, 0.06); border-radius: 10px; border-left: 3px solid #94a3b8;">
        <p style="font-weight: 600; font-size: 0.9rem; color: #94a3b8; margin-bottom: 0.5rem;"
          data-i18n-en="Labeled MLE: Noise Explosion"
          data-i18n-zh="标签 MLE：噪声爆炸">Labeled MLE: Noise Explosion</p>
        <p style="font-size: 0.8rem; color: var(--text-muted); margin-bottom: 0.5rem;"
          data-i18n-en="Estimates velocity as v &approx; &Delta;X/&Delta;t. When &Delta;t &rarr; 0, noise &prop; &sigma;/&radic;&Delta;t &rarr; &infin;. When &Delta;t is large, O(&Delta;t) discretization bias accumulates over N&minus;1 interaction terms."
          data-i18n-zh="将速度估计为 v &approx; &Delta;X/&Delta;t。当 &Delta;t &rarr; 0 时，噪声 &prop; &sigma;/&radic;&Delta;t &rarr; &infin;。当 &Delta;t 大时，O(&Delta;t) 离散化偏差在 N&minus;1 个交互项上累积。">
          Estimates velocity as v &approx; &Delta;X/&Delta;t. When &Delta;t &rarr; 0, noise &prop; &sigma;/&radic;&Delta;t &rarr; &infin;. When &Delta;t is large, O(&Delta;t) discretization bias accumulates over N&minus;1 interaction terms.
        </p>
        <p style="font-size: 0.8rem; font-family: var(--font-mono); color: #ef4444; margin: 0;"
          data-i18n-en="&nabla;V: 0.8% &rarr; 11.3% as &Delta;t grows"
          data-i18n-zh="&nabla;V: 0.8% &rarr; 11.3% 随 &Delta;t 增大">&nabla;V: 0.8% &rarr; 11.3% as &Delta;t grows</p>
      </div>
      <div style="padding: 1rem 1.25rem; background: rgba(167, 139, 250, 0.06); border-radius: 10px; border-left: 3px solid #a78bfa;">
        <p style="font-weight: 600; font-size: 0.9rem; color: #a78bfa; margin-bottom: 0.5rem;"
          data-i18n-en="Sinkhorn MLE: Matching Collapse"
          data-i18n-zh="Sinkhorn MLE：匹配崩溃">Sinkhorn MLE: Matching Collapse</p>
        <p style="font-size: 0.8rem; color: var(--text-muted); margin-bottom: 0.5rem;"
          data-i18n-en="Uses optimal transport to guess which particle is which. At small &Delta;t, works well (particles barely move). At large &Delta;t, particles mix completely — matching accuracy drops to 24.5%, near the 10% random baseline."
          data-i18n-zh="用最优传输猜测哪个粒子是哪个。&Delta;t 小时效果好（粒子几乎不动）。&Delta;t 大时，粒子完全混合——匹配精度降至 24.5%，接近 10% 随机基线。">
          Uses optimal transport to guess which particle is which. At small &Delta;t, works well (particles barely move). At large &Delta;t, particles mix completely — matching accuracy drops to 24.5%, near the 10% random baseline.
        </p>
        <p style="font-size: 0.8rem; font-family: var(--font-mono); color: #ef4444; margin: 0;"
          data-i18n-en="&nabla;&Phi;: 0.8% &rarr; 95.8% as &Delta;t grows"
          data-i18n-zh="&nabla;&Phi;: 0.8% &rarr; 95.8% 随 &Delta;t 增大">&nabla;&Phi;: 0.8% &rarr; 95.8% as &Delta;t grows</p>
      </div>
    </div>

    <div style="text-align: center; margin-top: 1rem; padding: 0.75rem; background: rgba(34, 197, 94, 0.06); border-radius: 8px; border: 1px solid rgba(34, 197, 94, 0.15);">
      <p style="margin: 0; font-size: 0.85rem; color: #22c55e; font-weight: 600;"
        data-i18n-en="Our self-test avoids both pitfalls: no velocity estimation, no trajectory matching"
        data-i18n-zh="我们的自测同时避开了两个陷阱：无需速度估计，无需轨迹匹配">
        Our self-test avoids both pitfalls: no velocity estimation, no trajectory matching
      </p>
      <p style="margin: 0.25rem 0 0; font-size: 0.8rem; font-family: var(--font-mono); color: var(--text-muted);"
        data-i18n-en="Self-Test &nabla;V: 0.67% &rarr; 6.84%. In the same large-&Delta;t benchmark row, Sinkhorn degrades much more severely."
        data-i18n-zh="自测 &nabla;V: 0.67% &rarr; 6.84%。在同一个大 &Delta;t benchmark 行里，Sinkhorn 的退化要严重得多。">
        Self-Test &nabla;V: 0.67% &rarr; 6.84%. In the same large-&Delta;t benchmark row, Sinkhorn degrades much more severely.
      </p>
    </div>
  </section>

  <div class="section-divider"></div>

  <!-- ═══ BUT: Failed Approach 2 — Distribution Matching ═══ -->
  <section id="dist-matching-fail" class="section section-wide">
    <p class="section-label" data-i18n-en="But Approach 2 Also Fails" data-i18n-zh="但方法2也不行">But Approach 2 Also Fails</p>
    <h2 data-i18n-en="Distribution Matching: Correct Idea, Prohibitive Cost" data-i18n-zh="分布匹配：想法对，代价不可承受">Distribution Matching: Correct Idea, Prohibitive Cost</h2>
    <p data-i18n-en="Avoid labels entirely by minimizing Wasserstein distance between predicted and observed distributions. Sounds reasonable — BUT this requires simulating the full particle system at EVERY gradient step. For N=10 particles over 1000+ optimization steps, the compute cost explodes." data-i18n-zh="通过最小化预测分布和观测分布之间的 Wasserstein 距离来完全避免标签。听起来合理——但这需要在每个梯度步骤模拟完整粒子系统。对于 N=10 的粒子，超过 1000+ 优化步骤，计算代价爆炸。">
      Avoid labels entirely by minimizing Wasserstein distance between predicted and observed distributions. Sounds reasonable — BUT this requires simulating the full particle system at EVERY gradient step. For N=10 particles over 1000+ optimization steps, the compute cost explodes.
    </p>
    <div class="demo-container">
      <div class="demo-label" data-i18n-en="Drag to see how cost scales with number of particles" data-i18n-zh="拖动查看代价如何随粒子数扩展">Drag to see how cost scales</div>
      <div style="display:flex;align-items:center;gap:0.75rem;margin:0.75rem 0;padding:0 1rem;">
        <label style="font-size:0.875rem;white-space:nowrap;" data-i18n-en="N =" data-i18n-zh="N =">N = <span id="n-particles-value" style="font-family:var(--font-mono);color:var(--accent-cyan);">20</span></label>
        <input type="range" id="n-particles-slider" min="5" max="100" step="5" value="20" style="flex:1;accent-color:var(--accent-cyan);" />
      </div>
      <div class="demo-canvas-wrap" style="aspect-ratio:3/1;"><canvas id="dist-matching-canvas"></canvas></div>
    </div>
    <div class="callout callout-warning" style="margin-top:1.5rem;">
      <p data-i18n-en="Failure type: computational. Wasserstein minimization requires O(N² × optimization_steps) work — intractable for large systems." data-i18n-zh="失败类型：计算性。Wasserstein 最小化需要 O(N² × 优化步骤) 的工作量——对于大系统不可行。">
        Failure type: computational. Wasserstein minimization requires O(N&sup2; &times; optimization_steps) work — intractable for large systems.
      </p>
    </div>
  </section>

  <!-- ═══ BUT: Failed Approach 3 — Mean-Field Shortcut ═══ -->
  <section id="mean-field-fail" class="section section-wide">
    <p class="section-label" data-i18n-en="And Approach 3 Also Fails" data-i18n-zh="方法3也不行">And Approach 3 Also Fails</p>
    <h2 data-i18n-en="Mean-Field: Elegant Theory, Wrong Regime" data-i18n-zh="均场：优雅的理论，错误的范围">Mean-Field: Elegant Theory, Wrong Regime</h2>
    <p data-i18n-en="For N→∞, the empirical measure converges to a smooth density satisfying a partial differential equation (PDE) — enabling clean inference. BUT: we care about finite N. At N=10, the empirical measure is 10 discrete delta spikes. Mean-field theory breaks down exactly here." data-i18n-zh="当 N→∞ 时，经验测度收敛到满足偏微分方程（PDE）的光滑密度——支持干净的推断。但：我们关心有限 N。在 N=10 时，经验测度是 10 个离散 delta 尖峰。均场理论在此处正好失效。">
      For N&rarr;&infin;, the empirical measure converges to a smooth density satisfying a partial differential equation (PDE) — enabling clean inference. BUT: we care about finite N. At N=10, the empirical measure is 10 discrete delta spikes. Mean-field theory breaks down exactly here.
    </p>
    <div class="demo-container">
      <div class="demo-label" data-i18n-en="Drag N — observe when empirical measure becomes smooth enough for mean-field" data-i18n-zh="拖动 N——观察经验测度何时足够光滑以使用均场">Drag N — observe when empirical measure becomes smooth enough for mean-field</div>
      <div style="display:flex;align-items:center;gap:0.75rem;margin:0.75rem 0;padding:0 1rem;">
        <label style="font-size:0.875rem;white-space:nowrap;" data-i18n-en="N =" data-i18n-zh="N =">N = <span id="mean-field-n-value" style="font-family:var(--font-mono);color:var(--accent-cyan);">10</span></label>
        <input type="range" id="mean-field-n-slider" min="5" max="200" step="5" value="10" style="flex:1;accent-color:var(--accent-cyan);" />
      </div>
      <div class="demo-canvas-wrap" style="aspect-ratio:2/1;"><canvas id="mean-field-canvas"></canvas></div>
    </div>
    <div class="callout callout-warning" style="margin-top:1.5rem;">
      <p data-i18n-en="Failure type: theoretical. Mean-field is valid only as N→∞. Our paper uses N=10. The approximation error from mean-field is O(1/N) — at N=10, this is 10% error before we've even started." data-i18n-zh="失败类型：理论性。均场仅在 N→∞ 时有效。我们的论文使用 N=10。均场近似误差为 O(1/N)——在 N=10 时，这是 10% 的误差，甚至还没开始学习。">
        Failure type: theoretical. Mean-field is valid only as N&rarr;&infin;. Our paper uses N=10. The approximation error from mean-field is O(1/N) — at N=10, this is 10% error before we've even started.
      </p>
    </div>
    <!-- COGNITIVE GATE 1 -->
    <div class="cognitive-gate" style="text-align:center;margin-top:2rem;padding:1.5rem;background:rgba(79,156,249,0.05);border:1px solid rgba(79,156,249,0.2);border-radius:12px;">
      <p style="margin:0 0 1rem;color:rgba(255,255,255,0.7);font-size:0.9rem;" data-i18n-en="Three approaches. Three distinct failures. Time to ask a different question." data-i18n-zh="三种方法。三种不同的失败。该换一种问法了。">Three approaches. Three distinct failures. Time to ask a different question.</p>
      <button id="gate-approaches-btn" class="btn btn-primary" style="font-size:1rem;" data-i18n-en="I see why obvious approaches fail — show me the right question →" data-i18n-zh="我明白了为什么这些方法不对路——告诉我正确的问法 →">I see why obvious approaches fail — show me the right question &rarr;</button>
    </div>
  </section>

  <!-- ═══ THEREFORE: The Pivot ═══ -->
  <section id="pivot" class="section section-wide" style="display:none;">
    <p class="section-label" data-i18n-en="The Key Reframe" data-i18n-zh="关键重构">The Key Reframe</p>
    <h2 data-i18n-en="Stop Recovering What's Missing. Start From What We Have." data-i18n-zh="停止恢复缺失信息。从我们拥有的开始。">Stop Recovering What's Missing. Start From What We Have.</h2>
    <p data-i18n-en="Every failed approach tried to RECOVER hidden information: labels, trajectories, or smooth density. None asked: what object do we ACTUALLY observe from unlabeled snapshots? And what can we build from THAT?" data-i18n-zh="每种失败方法都试图恢复隐藏信息：标签、轨迹或光滑密度。没有人问：我们从无标签快照实际观测到的对象是什么？我们能用这个对象做什么？">
      Every failed approach tried to RECOVER hidden information: labels, trajectories, or smooth density. None asked: what object do we ACTUALLY observe from unlabeled snapshots? And what can we build from THAT?
    </p>
    <div class="demo-container">
      <p id="pivot-phase-label" style="text-align:center;color:var(--accent-cyan);font-size:0.9rem;margin-bottom:0.75rem;padding-top:0.75rem;">Phase 1: Labeled trajectories (classical setting)</p>
      <div class="demo-canvas-wrap" style="aspect-ratio:5/2;"><canvas id="pivot-canvas"></canvas></div>
      <div style="text-align:center;margin-top:0.75rem;padding-bottom:0.75rem;">
        <button id="pivot-next-btn" class="btn btn-outline" data-i18n-en="Erase labels →" data-i18n-zh="抹去标签 →">Erase labels &rarr;</button>
      </div>
    </div>
    <div class="callout callout-insight" style="margin-top:1.5rem;">
      <p data-i18n-en="This is the empirical measure μₙ = (1/N)∑ᵢ δ_{Xᵢ}. It is NOT a degraded version of trajectories. It is a different mathematical object — a random sum of N Dirac delta masses. And crucially: it has its own evolution equation." data-i18n-zh="这是经验测度 μₙ = (1/N)∑ᵢ δ_{Xᵢ}。它不是轨迹的退化版本。它是一个不同的数学对象——N 个 Dirac delta 质量的随机和。关键是：它有自己的演化方程。">
        This is the empirical measure &mu;<sub>n</sub> = (1/N)&sum;<sub>i</sub> &delta;<sub>X<sub>i</sub></sub>. It is NOT a degraded version of trajectories. It is a different mathematical object — a random sum of N Dirac delta masses. And crucially: it has its own evolution equation.
      </p>
    </div>
  </section>

  <!-- ═══ THEREFORE: Why Weak Form is FORCED ═══ -->
  <section id="weak-form-necessity" class="section" style="display:none;">
    <p class="section-label" data-i18n-en="Why This Formulation" data-i18n-zh="为什么是这个公式">Why This Formulation</p>
    <h2 data-i18n-en="The Observable Forces the Formulation" data-i18n-zh="可观测量迫使我们进入这个公式">The Observable Forces the Formulation</h2>
    <div style="display:grid;grid-template-columns:1fr 1fr;gap:1.5rem;margin:1.5rem 0;">
      <div style="padding:1.25rem;background:rgba(239,68,68,0.06);border:1px solid rgba(239,68,68,0.25);border-radius:12px;">
        <h4 style="color:#ef4444;margin:0 0 0.5rem;" data-i18n-en="Pointwise Equation: Impossible" data-i18n-zh="逐点方程：不可能">Pointwise Equation: Impossible</h4>
        <p style="font-size:0.85rem;color:rgba(255,255,255,0.6);margin:0;" data-i18n-en="μₙ is a sum of delta spikes. Try ∂μₙ/∂x at a particle location: it's ∞. Pointwise derivatives don't exist for delta masses. We CANNOT write ∂ₜμₙ = ... in the classical sense." data-i18n-zh="μₙ 是 delta 尖峰的和。在粒子位置求 ∂μₙ/∂x：结果是 ∞。逐点导数对 delta 质量不存在。我们无法以经典意义写出 ∂ₜμₙ = ...">
          &mu;<sub>n</sub> is a sum of delta spikes. Try &part;&mu;<sub>n</sub>/&part;x at a particle location: it's &infin;. Pointwise derivatives don't exist for delta masses. We CANNOT write &part;<sub>t</sub>&mu;<sub>n</sub> = ... in the classical sense.
        </p>
      </div>
      <div style="padding:1.25rem;background:rgba(34,197,94,0.06);border:1px solid rgba(34,197,94,0.25);border-radius:12px;">
        <h4 style="color:#22c55e;margin:0 0 0.5rem;" data-i18n-en="Weak Form: The Only Path" data-i18n-zh="弱形式：唯一的路">Weak Form: The Only Path</h4>
        <p style="font-size:0.85rem;color:rgba(255,255,255,0.6);margin:0;" data-i18n-en="∫ψ dμₙ = (1/N)∑ᵢ ψ(Xᵢ). This is computable from any snapshot. Weak form turns the problem into: find (V,Φ) such that this empirical average matches the predicted evolution for all test functions ψ." data-i18n-zh="∫ψ dμₙ = (1/N)∑ᵢ ψ(Xᵢ)。这可以从任何快照计算。弱形式把问题变成：找到 (V,Φ) 使得对所有测试函数 ψ，这个经验平均与预测演化匹配。">
          &int;&psi; d&mu;<sub>n</sub> = (1/N)&sum;<sub>i</sub> &psi;(X<sub>i</sub>). This is computable from any snapshot. Weak form turns the problem into: find (V,&Phi;) such that this empirical average matches the predicted evolution for all test functions &psi;.
        </p>
      </div>
    </div>
    <blockquote style="border-left:3px solid var(--accent-cyan);padding:1rem 1.5rem;margin:1.5rem 0;color:rgba(255,255,255,0.85);font-style:italic;background:rgba(79,156,249,0.04);border-radius:0 8px 8px 0;">
      <span data-i18n-en='"We do not move to weak form because it is fancy. We move because the observable itself forces us to."' data-i18n-zh='"我们进入弱形式，不是因为它更高级。而是因为可观测量本身迫使我们这么做。"'>"We do not move to weak form because it is fancy. We move because the observable itself forces us to."</span>
    </blockquote>
  </section>

  <!-- ═══ THEREFORE: Design Criteria Gate ═══ -->
  <section id="design-criteria" class="section section-wide" style="display:none;">
    <p class="section-label" data-i18n-en="What Must Any Solution Satisfy?" data-i18n-zh="任何解法必须满足什么？">What Must Any Solution Satisfy?</p>
    <h2 data-i18n-en="Three Criteria for a Valid Test Family" data-i18n-zh="有效测试函数族的三条标准">Three Criteria for a Valid Test Family</h2>
    <p data-i18n-en="Weak form reduces the problem to: choose a test function family ψ. But not any family works. Before we reveal the answer, check off each criterion that any valid family must satisfy." data-i18n-zh="弱形式把问题化简为：选择一个测试函数族 ψ。但并非任意族都能奏效。在我们揭示答案之前，检查任何有效族必须满足的每条标准。">
      Weak form reduces the problem to: choose a test function family &psi;. But not any family works. Before we reveal the answer, check off each criterion that any valid family must satisfy.
    </p>
    <div id="criteria-gate-container"></div>
    <div id="self-test-reveal" style="display:none;margin-top:2rem;">
      <div class="callout callout-success" style="border-color:var(--accent-green);">
        <h3 style="margin:0 0 0.75rem;" data-i18n-en="The Self-Test Family: ψ = V + Φ*μ" data-i18n-zh="自测函数族：ψ = V + Φ*μ">The Self-Test Family: &psi; = V + &Phi;*&mu;</h3>
        <p style="margin:0;" data-i18n-en="Use the candidate potential ITSELF as the test function. This family satisfies all three criteria automatically: it's computable from μₙ, it's linear in (V,Φ), and it induces a well-structured (symmetric, non-negative) bilinear form. The self-test family is not a trick — it is the natural answer to the test-function design problem." data-i18n-zh="用候选势函数本身作为测试函数。这个族自动满足所有三条标准：可从 μₙ 计算、对 (V,Φ) 线性、诱导一个结构良好（对称、非负）双线性型。自测函数族不是技巧——它是测试函数设计问题的自然答案。">
          Use the candidate potential ITSELF as the test function. This family satisfies all three criteria automatically: it's computable from &mu;<sub>n</sub>, it's linear in (V,&Phi;), and it induces a well-structured (symmetric, non-negative) bilinear form. The self-test family is not a trick — it is the natural answer to the test-function design problem.
        </p>
      </div>
    </div>
  </section>

  <div class="section-divider"></div>

  <!-- ═══ Section 4: Our Approach — The Weak Form PDE ═══ -->
  <section id="insight" class="section section-wide">
    <p class="section-label"
      data-i18n-en="Our Approach"
      data-i18n-zh="我们的方法">Our Approach</p>
    <h2 data-i18n-en="From Particles to Distributions: The Weak Form PDE"
        data-i18n-zh="从粒子到分布：弱形式 PDE">From Particles to Distributions: The Weak Form PDE</h2>

    <!-- Step 1: The key realization -->
    <div class="callout callout-insight" style="margin-bottom: 2rem; border-left: 3px solid var(--accent-cyan);">
      <p style="margin: 0; font-size: 0.95rem;"
        data-i18n-en="Key realization: we don't need to track individual particles. The empirical measure &mu;<sub>t</sub><sup>N</sup> = (1/N)&sum;<sub>i</sub>&delta;<sub>X_t^i</sub> is directly observable from unlabeled snapshots. More importantly, it satisfies a weak-form stochastic evolution equation whose dependence on V and &Phi; is linear. This turns the N! matching problem into a functional optimization problem."
        data-i18n-zh="关键洞察：我们不需要追踪单个粒子。经验测度 &mu;<sub>t</sub><sup>N</sup> = (1/N)&sum;<sub>i</sub>&delta;<sub>X_t^i</sub> 可以从无标签快照直接观测。更重要的是，它满足一个关于 V 和 &Phi; 线性的弱形式随机演化方程，于是 N! 的匹配问题被转化为泛函优化问题。">
        Key realization: we don't need to track individual particles. The empirical measure &mu;<sub>t</sub><sup>N</sup> = (1/N)&sum;<sub>i</sub>&delta;<sub>X_t^i</sub> is directly observable from unlabeled snapshots. More importantly, it satisfies a weak-form stochastic evolution equation whose dependence on V and &Phi; is linear. This turns the N! matching problem into a functional optimization problem.
      </p>
    </div>

    <!-- Step 2: Why the Weak Form? -->
    <h3 data-i18n-en="Why the Weak Form?"
        data-i18n-zh="为什么用弱形式？">Why the Weak Form?</h3>
    <p data-i18n-en="The empirical measure &mu;<sub>t</sub><sup>N</sup> satisfies a weak-form stochastic evolution equation. Because &mu;<sub>t</sub><sup>N</sup> is a sum of delta masses, its derivatives are understood distributionally rather than pointwise. The weak form handles this by testing the equation against a smooth function &psi; and integrating by parts, so everything reduces to empirical averages over particle positions that are directly computable from snapshots."
       data-i18n-zh="经验测度 &mu;<sub>t</sub><sup>N</sup> 满足一个弱形式随机演化方程。由于 &mu;<sub>t</sub><sup>N</sup> 是若干 delta 质量的和，它的导数只能在分布意义下理解，不能按普通函数逐点求导。弱形式的做法是用光滑测试函数 &psi; 去测试该方程并做分部积分，于是所有项都化为粒子位置的经验平均，可以直接由快照计算。">
      The empirical measure &mu;<sub>t</sub><sup>N</sup> satisfies a weak-form stochastic evolution equation. Because &mu;<sub>t</sub><sup>N</sup> is a sum of delta masses, its derivatives are understood distributionally rather than pointwise. The weak form handles this by testing the equation against a smooth function &psi; and integrating by parts, so everything reduces to empirical averages over particle positions that are directly computable from snapshots.
    </p>

    <div style="display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 1rem; margin: 1.5rem 0;">
      <div style="text-align: center; padding: 1rem; background: rgba(239, 68, 68, 0.06); border-radius: 10px; border-top: 3px solid #ef4444;">
        <p style="font-size: 0.75rem; text-transform: uppercase; letter-spacing: 0.1em; color: #ef4444; margin-bottom: 0.5rem;"
          data-i18n-en="Strong Form"
          data-i18n-zh="强形式">Strong Form</p>
        <p style="font-size: 0.85rem; color: var(--text-muted); margin: 0;"
          data-i18n-en="Requires distributional derivatives of &mu; — not directly usable pointwise for delta masses"
          data-i18n-zh="需要以分布意义理解 &mu; 的导数——对经验 delta 质量不能逐点直接使用">Requires distributional derivatives of &mu; — not directly usable pointwise for delta masses</p>
      </div>
      <div style="text-align: center; padding: 1rem; background: rgba(34, 197, 94, 0.06); border-radius: 10px; border-top: 3px solid #22c55e;">
        <p style="font-size: 0.75rem; text-transform: uppercase; letter-spacing: 0.1em; color: #22c55e; margin-bottom: 0.5rem;"
          data-i18n-en="Weak Form"
          data-i18n-zh="弱形式">Weak Form</p>
        <p style="font-size: 0.85rem; color: var(--text-muted); margin: 0;"
          data-i18n-en="Only needs &int;&psi; d&mu; = (1/N)&sum;&psi;(X&#7522;) — computable!"
          data-i18n-zh="只需 &int;&psi; d&mu; = (1/N)&sum;&psi;(X&#7522;) — 可计算！">Only needs &int;&psi; d&mu; = (1/N)&sum;&psi;(X&#7522;) — computable!</p>
      </div>
      <div style="text-align: center; padding: 1rem; background: rgba(59, 130, 246, 0.06); border-radius: 10px; border-top: 3px solid #3b82f6;">
        <p style="font-size: 0.75rem; text-transform: uppercase; letter-spacing: 0.1em; color: #3b82f6; margin-bottom: 0.5rem;"
          data-i18n-en="Key Property"
          data-i18n-zh="关键性质">Key Property</p>
        <p style="font-size: 0.85rem; color: var(--text-muted); margin: 0;"
          data-i18n-en="Linear in the unknown potentials &rarr; quadratic loss in the parametric setting"
          data-i18n-zh="对未知势线性 &rarr; 在线性参数化下得到二次损失">Linear in the unknown potentials &rarr; quadratic loss in the parametric setting</p>
      </div>
    </div>

    <p data-i18n-en="The crucial advantage: because the weak form PDE is linear in V and &Phi;, we can choose the test function &psi; to be V and &Phi; themselves. This self-testing trick — using the unknowns as their own test functions — produces a loss with a remarkable property."
       data-i18n-zh="关键优势：由于弱形式 PDE 关于 V 和 &Phi; 是线性的，我们可以选择测试函数 &psi; 就是 V 和 &Phi; 本身。这个自测技巧——用未知量作为自己的测试函数——产生了一个具有显著性质的损失函数。">
      The crucial advantage: because the weak form PDE is linear in V and &Phi;, we can choose the test function &psi; to be V and &Phi; themselves. This self-testing trick — using the unknowns as their own test functions — produces a loss with a remarkable property.
    </p>

    <!-- Step 3: The Self-Test Loss -->
    <h3 style="margin-top: 2.5rem;"
      data-i18n-en="The Self-Test Loss"
      data-i18n-zh="自测损失函数">The Self-Test Loss</h3>
    <p data-i18n-en="Applying It&ocirc;'s formula with the self-testing family &psi; = V + &Phi;*&mu;, the weak-form residual decomposes into three computable terms. The associated free-energy increment uses E<sub>f</sub>(&mu;) = &lang;V + (1/2)&Phi;*&mu;, &mu;&rang;. Each term is an empirical average over particle snapshots — no velocity estimation, no trajectory matching."
       data-i18n-zh="以自测函数族 &psi; = V + &Phi;*&mu; 应用伊藤公式，弱形式残差分解为三个可计算项。对应的自由能增量使用 E<sub>f</sub>(&mu;) = &lang;V + (1/2)&Phi;*&mu;, &mu;&rang;。每一项都是粒子快照上的经验平均——无需速度估计，无需轨迹匹配。">
      Applying It&ocirc;'s formula with the self-testing family &psi; = V + &Phi;*&mu;, the weak-form residual decomposes into three computable terms. The associated free-energy increment uses E<sub>f</sub>(&mu;) = &lang;V + (1/2)&Phi;*&mu;, &mu;&rang;. Each term is an empirical average over particle snapshots — no velocity estimation, no trajectory matching.
    </p>

    <div class="math-block">
      <Math tex={String.raw`\mathcal{L}(\theta) = \frac{1}{2}\, J_{\text{diss}}\, \Delta t \;-\; \frac{\sigma^2}{2}\, J_{\text{diff}}\, \Delta t \;+\; \delta E_f`} />
    </div>

    <!-- Loss Anatomy -->
    <h3 style="margin-top: 2.5rem;"
      data-i18n-en="Anatomy of the Loss"
      data-i18n-zh="损失函数解剖">Anatomy of the Loss</h3>
    <p data-i18n-en="Each term comes from testing the weak-form equation against &psi; = V + &Phi;*&mu;. The last term is the free-energy increment associated with E<sub>f</sub>(&mu;) = &lang;V + (1/2)&Phi;*&mu;, &mu;&rang;:"
       data-i18n-zh="每一项都来自以 &psi; = V + &Phi;*&mu; 测试弱形式方程。最后一项是自由能 E<sub>f</sub>(&mu;) = &lang;V + (1/2)&Phi;*&mu;, &mu;&rang; 的增量：">
      Each term comes from testing the weak-form equation against &psi; = V + &Phi;*&mu;. The last term is the free-energy increment associated with E<sub>f</sub>(&mu;) = &lang;V + (1/2)&Phi;*&mu;, &mu;&rang;:
    </p>

    <div class="loss-anatomy">
      <div class="loss-anatomy-header">
        <div class="math-block" style="margin: 0; border-left-color: var(--accent-cyan);">
          <Math tex={String.raw`\mathcal{L} = \underbrace{\tfrac{1}{2}\, J_{\text{diss}}\, \Delta t}_{\color{#ef4444}\text{dissipation}} \;-\; \underbrace{\tfrac{\sigma^2}{2}\, J_{\text{diff}}\, \Delta t}_{\color{#3b82f6}\text{diffusion}} \;+\; \underbrace{\delta E_f}_{\color{#f59e0b}\text{free-energy change}}`} />
        </div>
      </div>

      <div class="loss-component">
        <div class="lc-color" style="background: #ef4444;"></div>
        <div class="lc-body">
          <h4 style="color: #ef4444;">
            J<sub>diss</sub> = &Sigma;&Vert;drift&Vert;&sup2; / N
          </h4>
          <p data-i18n-en="Dissipation: how much work the drift forces do. The 1/2 coefficient (from the self-test trick) is what breaks the degeneracy — it makes L(V*, &Phi;*) strictly negative."
             data-i18n-zh="耗散：漂移力做了多少功。1/2 系数（来自自测技巧）是打破退化的关键——它使 L(V*, &Phi;*) 严格为负。">
            Dissipation: how much work the drift forces do. The 1/2 coefficient (from the self-test trick) is what breaks the degeneracy — it makes L(V*, &Phi;*) strictly negative.
          </p>
        </div>
      </div>

      <div class="loss-component">
        <div class="lc-color" style="background: #3b82f6;"></div>
        <div class="lc-body">
          <h4 style="color: #3b82f6;">
            J<sub>diff</sub> = (1/N) &Sigma;<sub>i</sub>&Delta;V + (1/N&sup2;) &Sigma;<sub>i&ne;j</sub>&Delta;&Phi;
          </h4>
          <p data-i18n-en="Diffusion contribution: depends on the Laplacian of V and &Phi;. Computable from snapshots via the basis expansion or neural network parameterization."
             data-i18n-zh="扩散贡献：取决于 V 和 &Phi; 的拉普拉斯量。通过基函数展开或神经网络参数化可从快照计算。">
            Diffusion contribution: depends on the Laplacian of V and &Phi;. Computable from snapshots via the basis expansion or neural network parameterization.
          </p>
        </div>
      </div>

      <div class="loss-component">
        <div class="lc-color" style="background: #f59e0b;"></div>
        <div class="lc-body">
          <h4 style="color: #f59e0b;">
            &delta;E<sub>f</sub> = E<sub>f</sub>(t+&Delta;t) &minus; E<sub>f</sub>(t)
          </h4>
          <p data-i18n-en="For a candidate pair (V, &Phi;), the free-energy change between two unlabeled snapshots is computable without labels or trajectory matching."
             data-i18n-zh="对于给定候选势函数 (V, &Phi;)，两个无标签快照之间的自由能变化可以在不使用标签或轨迹匹配的情况下计算。">
            For a candidate pair (V, &Phi;), the free-energy change between two unlabeled snapshots is computable without labels or trajectory matching.
          </p>
        </div>
      </div>

      <div class="loss-anatomy-footer">
        <div class="math-block" style="margin: 0 0 0.5rem; padding: 0.75rem; background: transparent; border-left-color: var(--accent-green);">
          <Math tex={String.raw`\mathbb{E}[\mathcal{L}(V^*, \Phi^*)] = -\tfrac{1}{2}\,\mathbb{E}[J_{\text{diss}}^*\,\Delta t] < 0 \qquad \text{vs.} \qquad \mathcal{L}(0, 0) = 0`} />
        </div>
        <p style="margin: 0; color: #22c55e; font-size: 0.85rem;"
          data-i18n-en="The true potentials produce a strictly negative loss, while the trivial solution gives zero — this breaks the degeneracy that plagues squared-residual approaches."
          data-i18n-zh="真实势函数产生严格负的损失值，而平凡解给出零——这打破了困扰平方残差方法的退化性。">
          The true potentials produce a strictly negative loss, while the trivial solution gives zero — this breaks the degeneracy that plagues squared-residual approaches.
        </p>
      </div>
    </div>

    <!-- Loss Landscape -->
    <h3 style="margin-top: 3rem;"
      data-i18n-en="Why Not Just Square the Residual?"
      data-i18n-zh="为什么不直接对残差取平方？">Why Not Just Square the Residual?</h3>
    <p data-i18n-en="Squaring the weak form residual creates a degenerate minimum at V=0, &Phi;=0 (the trivial solution). By contrast, the self-test loss gives the true potentials a strictly lower population loss than the trivial pair, which breaks that degeneracy."
       data-i18n-zh="对弱形式残差取平方会在 V=0, &Phi;=0 处产生退化极小值（平凡解）。相比之下，自测损失在总体层面上会让真实势函数获得严格低于平凡解的损失值，从而打破这种退化。">
      Squaring the weak form residual creates a degenerate minimum at V=0, &Phi;=0 (the trivial solution). By contrast, the self-test loss gives the true potentials a strictly lower population loss than the trivial pair, which breaks that degeneracy.
    </p>

    <div class="demo-container">
      <div class="demo-canvas-wrap" style="aspect-ratio: 2/1;">
        <canvas id="loss-landscape-canvas"></canvas>
      </div>
    </div>

    <!-- Why Not Energy Balance? -->
    <h3 style="margin-top: 3rem;"
      data-i18n-en="Why Not Energy Balance?"
      data-i18n-zh="为什么不用能量平衡？">Why Not Energy Balance?</h3>
    <p data-i18n-en="One can derive a free-energy balance identity for the stochastic system via It&ocirc;'s formula, together with a martingale term. But using the squared residual of that identity for estimation is still a bad objective: J<sub>diss</sub> is already quadratic in V and &Phi;, so squaring the balance produces a quartic, non-convex optimization problem."
       data-i18n-zh="对这个随机系统，确实可以通过伊藤公式推导出带有鞅项的自由能平衡恒等式。但把该恒等式的平方残差直接拿来做估计仍然不是好目标：J<sub>diss</sub> 本身对 V 和 &Phi; 已经是二次的，再平方后就会得到四次、非凸的优化问题。">
      One can derive a free-energy balance identity for the stochastic system via It&ocirc;'s formula, together with a martingale term. But using the squared residual of that identity for estimation is still a bad objective: J<sub>diss</sub> is already quadratic in V and &Phi;, so squaring the balance produces a quartic, non-convex optimization problem.
    </p>

    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; margin: 1.5rem 0;">
      <div style="padding: 1rem 1.25rem; background: rgba(239, 68, 68, 0.06); border-radius: 10px; border-left: 3px solid #ef4444;">
        <p style="font-weight: 600; font-size: 0.9rem; color: #ef4444; margin-bottom: 0.5rem;"
          data-i18n-en="Energy Balance Approach"
          data-i18n-zh="能量平衡方法">Energy Balance Approach</p>
        <p style="font-size: 0.8rem; color: var(--text-muted); margin: 0;"
          data-i18n-en="Match the free-energy balance in expectation. Since J<sub>diss</sub> is already quadratic in V and &Phi;, squaring the residual yields a quartic, non-convex objective."
          data-i18n-zh="在期望意义下匹配自由能平衡。由于 J<sub>diss</sub> 对 V 和 &Phi; 已经是二次的，再平方就会得到四次、非凸目标。">
          Match the free-energy balance in expectation. Since J<sub>diss</sub> is already quadratic in V and &Phi;, squaring the residual yields a quartic, non-convex objective.
        </p>
      </div>
      <div style="padding: 1rem 1.25rem; background: rgba(34, 197, 94, 0.06); border-radius: 10px; border-left: 3px solid #22c55e;">
        <p style="font-weight: 600; font-size: 0.9rem; color: #22c55e; margin-bottom: 0.5rem;"
          data-i18n-en="Our Self-Test (Variation Approach)"
          data-i18n-zh="我们的自测（变分方法）">Our Self-Test (Variation Approach)</p>
        <p style="font-size: 0.8rem; color: var(--text-muted); margin: 0;"
          data-i18n-en="Test the weak-form PDE against &psi; = V + &Phi;*&mu;. The resulting loss stays quadratic; under linear parameterization it reduces to a convex linear-system solve."
          data-i18n-zh="以 &psi; = V + &Phi;*&mu; 测试弱形式 PDE。得到的损失保持二次结构；在线性参数化下可化为凸的线性系统求解。">
          Test the weak-form PDE against &psi; = V + &Phi;*&mu;. The resulting loss stays quadratic; under linear parameterization it reduces to a convex linear-system solve.
        </p>
      </div>
    </div>

    <p style="font-size: 0.85rem; color: var(--text-muted);"
      data-i18n-en="The demo below illustrates a free-energy balance identity. Near the ground-truth scales, the displayed terms nearly cancel. But turning that identity into an estimator would still require quartic optimization — exactly what the self-test avoids."
      data-i18n-zh="下面的演示展示了一个自由能平衡恒等式。在接近真值的缩放下，图中各项会近似抵消。但若直接把该恒等式变成估计器，仍然会落入四次优化——这正是自测要避免的。">
      The demo below illustrates a free-energy balance identity. Near the ground-truth scales, the displayed terms nearly cancel. But turning that identity into an estimator would still require quartic optimization — exactly what the self-test avoids.
    </p>

    <div class="callout callout-insight" style="margin-top: 1rem;">
      <p style="margin: 0;"
        data-i18n-en="Interpretation guide: this panel is a diagnostic visualization of the free-energy balance, not the training objective itself. The estimator we actually optimize is the quadratic self-test loss above."
        data-i18n-zh="阅读提示：下面这个面板展示的是自由能平衡恒等式的诊断性可视化，并不是训练时直接优化的目标。真正被优化的是上面的二次自测损失。">
        Interpretation guide: this panel is a diagnostic visualization of the free-energy balance, not the training objective itself. The estimator we actually optimize is the quadratic self-test loss above.
      </p>
    </div>

