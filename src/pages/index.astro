      <!-- C: Singularity (LJ) -->
      <div class="stress-card" style="border-left-color: #8b5cf6;">
        <p class="sc-title" style="color: #8b5cf6;">C: Singularity (Lennard-Jones)</p>
        <div class="math-block" style="margin: 0.35rem 0; padding: 0.4rem 0.6rem; font-size: 0.85rem;">
          <Math tex={String.raw`V = |x|^2, \quad \Phi = 4\varepsilon[(\sigma/r)^{12}-(\sigma/r)^{6}]`} />
        </div>
        <p class="sc-hypothesis"
          data-i18n-en="r⁻¹² blowup near origin → gradient explosion"
          data-i18n-zh="r⁻¹² 在原点附近爆炸 → 梯度爆炸">r<sup>&minus;12</sup> blowup near origin &rarr; gradient explosion</p>
        <p class="sc-result">&nabla;V: LSE 8.88% &middot; NN 1.91%</p>
