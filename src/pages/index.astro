    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1.5rem; margin: 2rem 0;">
      <!-- Oracle Self-Test card -->
      <div style="background: rgba(74, 222, 128, 0.06); border: 1px solid rgba(74, 222, 128, 0.2); border-radius: 12px; padding: 1.5rem;">
        <div style="display: flex; align-items: center; gap: 0.5rem; margin-bottom: 1rem;">
          <span style="font-size: 1.5rem;">&#x1F4D0;</span>
          <h3 style="margin: 0; font-size: 1.05rem; color: #4ade80;"
            data-i18n-en="Self-Test LSE"
