    <!-- Stress Test Result Cards -->
    <h3 style="margin-top: 2rem;"
      data-i18n-en="Results by Model"
      data-i18n-zh="各模型结果">Results by Model</h3>
    <p style="font-size: 0.85rem; color: var(--text-muted); margin-bottom: 0.75rem;"
      data-i18n-en="Each model tests one theoretical assumption. Data at d=2, Self-Test LSE vs NN."
      data-i18n-zh="每个模型测试一个理论假设。数据为 d=2，自测基函数 vs 神经网络。">
      Each model tests one theoretical assumption. Data at d=2, Self-Test LSE vs NN.
    </p>

    <div class="stress-cards">
      <!-- A: Smoothness -->
      <div class="stress-card" style="border-left-color: #22c55e;">
        <p class="sc-title" style="color: #22c55e;">A: Smoothness Test</p>
        <div class="math-block" style="margin: 0.35rem 0; padding: 0.4rem 0.6rem; font-size: 0.85rem;">
          <Math tex={String.raw`V = -\tfrac{1}{2}|x|+2|x|^2, \quad \Phi = -3\cdot\mathbf{1}_{[0.5,1]}+2\cdot\mathbf{1}_{[1,2]}`} />
        </div>
        <p class="sc-hypothesis"
          data-i18n-en="Piecewise-like &Phi; &rarr; stresses C&#8308; smoothness"
          data-i18n-zh="类分段 &Phi; &rarr; 挑战 C&#8308; 光滑性">Piecewise-like &Phi; &rarr; stresses C&#8308; smoothness</p>
        <p class="sc-result">&nabla;V: LSE 1.07% &middot; NN 1.76%</p>
