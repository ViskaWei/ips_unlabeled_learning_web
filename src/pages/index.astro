      <!-- B: Conditioning -->
      <div class="stress-card" style="border-left-color: #f59e0b;">
        <p class="sc-title" style="color: #f59e0b;">B: Conditioning Test</p>
        <div class="math-block" style="margin: 0.35rem 0; padding: 0.4rem 0.6rem; font-size: 0.85rem;">
          <Math tex={String.raw`V = \tfrac{1}{4}(|x|^2-1)^2 - \tfrac{1}{4}, \quad \Phi = -\frac{\gamma\,r}{r+1}`} />
        </div>
        <p class="sc-hypothesis"
          data-i18n-en="Slow 1/r decay &rarr; &kappa;(A) = 146K, ill-conditioned"
          data-i18n-zh="慢 1/r 衰减 &rarr; &kappa;(A) = 146K，病态">Slow 1/r decay &rarr; &kappa;(A) = 146K, ill-conditioned</p>
