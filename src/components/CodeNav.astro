---
interface Props {
  active: 'overview' | 'protocol';
}

const { active } = Astro.props;
const base = import.meta.env.BASE_URL;
---

<nav class="code-nav">
  <div class="code-nav-inner">
    <a href={`${base}/`} class="code-nav-back" data-i18n-en="&larr; Paper" data-i18n-zh="&larr; 论文">&larr; Paper</a>
    <div class="code-nav-tabs">
      <a
        href={`${base}/code/overview/`}
        class:list={['code-nav-tab', { active: active === 'overview' }]}
        data-i18n-en="Overview"
        data-i18n-zh="概览"
      >Overview</a>
      <a
        href={`${base}/code/protocol/`}
        class:list={['code-nav-tab', { active: active === 'protocol' }]}
        data-i18n-en="Protocol"
        data-i18n-zh="流程"
      >Protocol</a>
    </div>
    <div class="code-nav-actions">
      <button
        id="code-lang-toggle"
        class="toggle-btn active"
        title="Toggle language"
        data-title-en="Toggle language"
        data-title-zh="切换语言"
      >EN</button>
    </div>
  </div>
</nav>

<style>
  .code-nav {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    background: rgba(10, 14, 23, 0.85);
    backdrop-filter: blur(12px);
    border-bottom: 1px solid rgba(255, 255, 255, 0.06);
  }

  .code-nav-inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 1.5rem;
    height: 56px;
    display: flex;
    align-items: center;
    gap: 1.5rem;
  }

  .code-nav-back {
    font-size: 0.85rem;
    color: var(--text-muted);
    padding: 0.35rem 0.75rem;
    border-radius: 6px;
    transition: all var(--transition-fast);
    white-space: nowrap;
  }
  .code-nav-back:hover {
    color: var(--text-primary);
    background: rgba(255, 255, 255, 0.05);
  }

  .code-nav-tabs {
    display: flex;
    gap: 0.25rem;
    flex: 1;
  }

  .code-nav-tab {
    padding: 0.35rem 1rem;
    font-size: 0.85rem;
    color: var(--text-muted);
    border-radius: 6px;
    white-space: nowrap;
    transition: all var(--transition-fast);
  }
  .code-nav-tab:hover {
    color: var(--text-primary);
    background: rgba(255, 255, 255, 0.05);
  }
  .code-nav-tab.active {
    color: var(--accent-cyan);
    background: rgba(6, 182, 212, 0.1);
    font-weight: 500;
  }

  .code-nav-actions {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  #code-lang-toggle {
    font-size: 0.75rem;
    padding: 0.25rem 0.6rem;
    border-radius: 4px;
    background: rgba(255, 255, 255, 0.08);
    color: var(--text-secondary);
    border: 1px solid rgba(255, 255, 255, 0.1);
    cursor: pointer;
    transition: all var(--transition-fast);
  }
  #code-lang-toggle:hover {
    border-color: var(--accent-cyan);
    color: var(--accent-cyan);
  }
</style>

<script>
  const langBtn = document.getElementById('code-lang-toggle');
  const docLang = document.documentElement.lang.toLowerCase();
  let currentLang = localStorage.getItem('ips-lang') || (docLang.startsWith('zh') ? 'zh' : 'en');

  function updateLang() {
    if (langBtn) langBtn.textContent = currentLang.toUpperCase();
    if (langBtn) {
      const title = currentLang === 'en' ? langBtn.dataset.titleEn : langBtn.dataset.titleZh;
      if (title) langBtn.title = title;
    }
    document.documentElement.lang = currentLang;
    document.querySelectorAll('[data-i18n-en]').forEach((el) => {
      const text = currentLang === 'en'
        ? el.getAttribute('data-i18n-en')
        : el.getAttribute('data-i18n-zh');
      if (text) el.innerHTML = text;
    });
    document.querySelectorAll<HTMLElement>('[data-title-en]').forEach((el) => {
      const title = currentLang === 'en' ? el.dataset.titleEn : el.dataset.titleZh;
      if (title) el.title = title;
    });
    document.querySelectorAll<HTMLElement>('[data-aria-label-en]').forEach((el) => {
      const label = currentLang === 'en' ? el.dataset.ariaLabelEn : el.dataset.ariaLabelZh;
      if (label) el.setAttribute('aria-label', label);
    });
    const pageTitle = document.querySelector('title[data-title-en]');
    if (pageTitle instanceof HTMLTitleElement) {
      pageTitle.textContent = currentLang === 'en' ? pageTitle.dataset.titleEn || '' : pageTitle.dataset.titleZh || '';
    }
    document.querySelectorAll<HTMLMetaElement>('meta[data-content-en]').forEach((el) => {
      const content = currentLang === 'en' ? el.dataset.contentEn : el.dataset.contentZh;
      if (content) el.setAttribute('content', content);
    });
    window.dispatchEvent(new CustomEvent('ips:langchange', { detail: { lang: currentLang } }));
  }

  langBtn?.addEventListener('click', () => {
    currentLang = currentLang === 'en' ? 'zh' : 'en';
    localStorage.setItem('ips-lang', currentLang);
    updateLang();
  });

  updateLang();
</script>
