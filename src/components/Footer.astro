---
const bibtex = `@article{wei2026learning,
  title={Learning interacting particle systems from unlabeled data},
  author={Wei, Viska and Lu, Fei},
  journal={arXiv preprint arXiv:2604.02581},
  year={2026}
}`;
---

<footer class="footer" id="footer">
  <div class="footer-inner">
    <div class="footer-grid">
      <div>
        <h4 data-i18n-en="Paper" data-i18n-zh="论文">Paper</h4>
        <div class="footer-links">
          <a href="https://arxiv.org/abs/2604.02581" class="footer-link" data-i18n-en="Paper (arXiv)" data-i18n-zh="论文（arXiv）">Paper (arXiv)</a>
          <a href="https://github.com/ViskaWei/lips_unlabeled_data" class="footer-link" data-i18n-en="Code" data-i18n-zh="代码">Code</a>
          <a href="https://github.com/ViskaWei/ips_unlabeled_learning_web" class="footer-link" data-i18n-en="Website Source" data-i18n-zh="网站源码">Website Source</a>
        </div>
      </div>

      <div>
        <h4 data-i18n-en="Authors" data-i18n-zh="作者">Authors</h4>
        <p class="footer-text">Viska Wei &amp; Fei Lu</p>
        <p class="footer-text footer-muted" data-i18n-en="Johns Hopkins University" data-i18n-zh="约翰斯·霍普金斯大学">Johns Hopkins University</p>
      </div>

      <div>
        <h4 data-i18n-en="Citation" data-i18n-zh="引用">Citation</h4>
        <div class="bibtex-wrap">
          <pre class="bibtex"><code>{bibtex}</code></pre>
          <button
            id="copy-bibtex"
            class="btn btn-outline btn-sm"
            data-bibtex={bibtex}
            data-i18n-en="Copy BibTeX"
            data-i18n-zh="复制 BibTeX"
            data-copied-en="Copied!"
            data-copied-zh="已复制"
          >Copy BibTeX</button>
        </div>
      </div>
    </div>

    <div class="footer-bottom">
      <p class="footer-muted" data-i18n-en="&copy; 2026 Viska Wei &amp; Fei Lu. Built with Astro, Three.js, and D3." data-i18n-zh="&copy; 2026 Viska Wei &amp; Fei Lu。使用 Astro、Three.js 和 D3 构建。">&copy; 2026 Viska Wei &amp; Fei Lu. Built with Astro, Three.js, and D3.</p>
    </div>
  </div>
</footer>

<style>
  .footer {
    background: var(--bg-secondary);
    border-top: 1px solid rgba(255, 255, 255, 0.06);
    padding: 4rem 1.5rem 2rem;
  }

  .footer-inner {
    max-width: 1100px;
    margin: 0 auto;
  }

  .footer-grid {
    display: grid;
    grid-template-columns: 1fr 1fr 2fr;
    gap: 3rem;
    margin-bottom: 3rem;
  }

  .footer h4 {
    font-size: 0.85rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--text-muted);
    margin-bottom: 1rem;
  }

  .footer-links {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .footer-link {
    font-size: 0.9rem;
    color: var(--text-secondary);
  }
  .footer-link:hover {
    color: var(--accent-cyan);
  }

  .footer-text {
    font-size: 0.9rem;
    margin-bottom: 0.25rem;
  }

  .footer-muted {
    color: var(--text-muted);
    font-size: 0.8rem;
  }

  .bibtex-wrap {
    position: relative;
  }

  .bibtex {
    background: var(--bg-code);
    border-radius: 8px;
    padding: 0.75rem 1rem;
    font-size: 0.72rem;
    font-family: var(--font-mono);
    color: var(--text-muted);
    overflow-x: auto;
    line-height: 1.5;
    margin-bottom: 0.5rem;
  }

  .btn-sm {
    font-size: 0.75rem;
    padding: 0.3rem 0.75rem;
  }

  .footer-bottom {
    border-top: 1px solid rgba(255, 255, 255, 0.06);
    padding-top: 1.5rem;
    text-align: center;
  }

  @media (max-width: 768px) {
    .footer-grid { grid-template-columns: 1fr; gap: 2rem; }
  }
</style>

<script>
  function copyButtonIdleText(btn) {
    return document.documentElement.lang === 'zh' ? btn.dataset.i18nZh : btn.dataset.i18nEn;
  }

  document.getElementById('copy-bibtex')?.addEventListener('click', (e) => {
    const btn = e.currentTarget as HTMLButtonElement;
    const text = btn.dataset.bibtex || '';
    navigator.clipboard.writeText(text).then(() => {
      btn.textContent = document.documentElement.lang === 'zh' ? btn.dataset.copiedZh || '' : btn.dataset.copiedEn || '';
      setTimeout(() => { btn.textContent = copyButtonIdleText(btn) || ''; }, 2000);
    });
  });

  window.addEventListener('ips:langchange', () => {
    const btn = document.getElementById('copy-bibtex') as HTMLButtonElement | null;
    if (btn) btn.textContent = copyButtonIdleText(btn) || '';
  });
</script>
