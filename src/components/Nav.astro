---
const sections = [
  { id: 'problem', labelEn: 'The Problem', labelZh: '核心问题' },
  { id: 'challenge', labelEn: 'Why It\'s Hard', labelZh: '为什么难' },
  { id: 'insight', labelEn: 'Our Approach', labelZh: '我们的方法' },
  { id: 'models', labelEn: 'Models', labelZh: '模型' },
  { id: 'results', labelEn: 'Results', labelZh: '结果' },
  { id: 'deep-dive', labelEn: 'Deep Dive', labelZh: '深入' },
];
const base = import.meta.env.BASE_URL;
---

<nav class="nav">
  <div class="nav-inner">
    <a href="https://viskawei.github.io/" class="nav-home">&larr;</a>
    <a href={`${base}/`} class="nav-brand">IPS</a>
    <div class="nav-links">
      {sections.map((s) => (
        <a
          href={`${base}/#${s.id}`}
          class="nav-link"
          data-i18n-en={s.labelEn}
          data-i18n-zh={s.labelZh}
        >{s.labelEn}</a>
      ))}
      <span class="nav-separator"></span>
      <a href={`${base}/demo/`} class="nav-link nav-link-page" data-i18n-en="Demo" data-i18n-zh="演示">Demo</a>
      <a href={`${base}/code/overview/`} class="nav-link nav-link-page" data-i18n-en="Code" data-i18n-zh="代码">Code</a>
      <a href={`${base}/code/api/`} class="nav-link nav-link-page">API</a>
    </div>
    <div class="nav-actions">
      <button
        id="lang-toggle"
        class="toggle-btn active"
        title="Toggle language"
        data-title-en="Toggle language"
        data-title-zh="切换语言"
      >EN</button>
      <button
        id="nav-hamburger"
        class="nav-hamburger"
        aria-label="Menu"
        data-label-en="Menu"
        data-label-zh="菜单"
      >
        <span></span><span></span><span></span>
      </button>
    </div>
  </div>
  <div id="nav-mobile" class="nav-mobile">
    {sections.map((s) => (
      <a
        href={`${base}/#${s.id}`}
        class="nav-mobile-link"
        data-i18n-en={s.labelEn}
        data-i18n-zh={s.labelZh}
      >{s.labelEn}</a>
    ))}
    <a href={`${base}/demo/`} class="nav-mobile-link nav-link-page" data-i18n-en="Demo" data-i18n-zh="演示">Demo</a>
    <a href={`${base}/code/overview/`} class="nav-mobile-link nav-link-page" data-i18n-en="Code" data-i18n-zh="代码">Code</a>
    <a href={`${base}/code/api/`} class="nav-mobile-link nav-link-page">API</a>
  </div>
</nav>

<style>
  .nav {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    background: rgba(10, 14, 23, 0.85);
    backdrop-filter: blur(12px);
    border-bottom: 1px solid rgba(255, 255, 255, 0.06);
    transition: background 0.3s ease;
  }

  .nav-inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 1.5rem;
    height: 56px;
    display: flex;
    align-items: center;
    gap: 1.5rem;
  }

  .nav-home {
    font-size: 0.85rem;
    color: var(--text-muted);
    padding: 0.35rem 0.5rem;
    border-radius: 6px;
    transition: all var(--transition-fast);
    flex-shrink: 0;
  }
  .nav-home:hover {
    color: var(--text-primary);
    background: rgba(255, 255, 255, 0.05);
  }

  .nav-brand {
    font-weight: 700;
    font-size: 1.1rem;
    background: var(--gradient-accent);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .nav-links {
    display: flex;
    gap: 0.25rem;
    flex: 1;
    overflow-x: auto;
  }

  .nav-link {
    padding: 0.35rem 0.75rem;
    font-size: 0.8rem;
    color: var(--text-muted);
    border-radius: 6px;
    white-space: nowrap;
    transition: all var(--transition-fast);
  }

  .nav-link:hover {
    color: var(--text-primary);
    background: rgba(255, 255, 255, 0.05);
  }
  .nav-link.active {
    color: var(--accent-cyan);
    background: rgba(34, 211, 238, 0.08);
    box-shadow: inset 0 -2px 0 var(--accent-cyan);
  }

  .nav-separator {
    width: 1px;
    height: 20px;
    background: rgba(255, 255, 255, 0.1);
    margin: 0 0.25rem;
    flex-shrink: 0;
  }

  .nav-link-page {
    color: var(--accent-cyan);
    font-weight: 500;
  }
  .nav-link-page:hover {
    color: var(--accent-blue);
    background: rgba(59, 130, 246, 0.1);
  }

  .nav-actions {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  #lang-toggle {
    font-size: 0.75rem;
    padding: 0.25rem 0.6rem;
    border-radius: 4px;
    background: rgba(255, 255, 255, 0.08);
    color: var(--text-secondary);
    border: 1px solid rgba(255, 255, 255, 0.1);
    cursor: pointer;
    transition: all var(--transition-fast);
  }
  #lang-toggle:hover {
    border-color: var(--accent-cyan);
    color: var(--accent-cyan);
  }

  /* ─── Hamburger button ─── */
  .nav-hamburger {
    display: none;
    flex-direction: column;
    gap: 4px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 6px;
  }
  .nav-hamburger span {
    display: block;
    width: 20px;
    height: 2px;
    background: var(--text-secondary);
    border-radius: 1px;
    transition: all 0.2s ease;
  }
  .nav-hamburger.open span:nth-child(1) { transform: rotate(45deg) translate(4px, 4px); }
  .nav-hamburger.open span:nth-child(2) { opacity: 0; }
  .nav-hamburger.open span:nth-child(3) { transform: rotate(-45deg) translate(4px, -4px); }

  /* ─── Mobile menu ─── */
  .nav-mobile {
    display: none;
    flex-direction: column;
    padding: 0.5rem 1.5rem 1rem;
    border-top: 1px solid rgba(255, 255, 255, 0.06);
  }
  .nav-mobile.open { display: flex; }
  .nav-mobile-link {
    padding: 0.6rem 0;
    font-size: 0.9rem;
    color: var(--text-secondary);
    border-bottom: 1px solid rgba(255, 255, 255, 0.04);
  }
  .nav-mobile-link:hover { color: var(--text-primary); }

  @media (max-width: 768px) {
    .nav-links { display: none; }
    .nav-hamburger { display: flex; }
  }
</style>

<script>
  // Language toggle
  const langBtn = document.getElementById('lang-toggle');
  const hamburger = document.getElementById('nav-hamburger');
  const docLang = document.documentElement.lang.toLowerCase();
  let currentLang = localStorage.getItem('ips-lang') || (docLang.startsWith('zh') ? 'zh' : 'en');

  function updateLang() {
    if (langBtn) langBtn.textContent = currentLang.toUpperCase();
    if (langBtn) {
      const title = currentLang === 'en' ? langBtn.dataset.titleEn : langBtn.dataset.titleZh;
      if (title) langBtn.title = title;
    }
    if (hamburger) {
      const label = currentLang === 'en' ? hamburger.dataset.labelEn : hamburger.dataset.labelZh;
      if (label) hamburger.setAttribute('aria-label', label);
    }
    document.documentElement.lang = currentLang;
    document.querySelectorAll('[data-i18n-en]').forEach((el) => {
      const text = currentLang === 'en'
        ? el.getAttribute('data-i18n-en')
        : el.getAttribute('data-i18n-zh');
      if (text) el.innerHTML = text;
    });
    document.querySelectorAll<HTMLElement>('[data-title-en]').forEach((el) => {
      const title = currentLang === 'en' ? el.dataset.titleEn : el.dataset.titleZh;
      if (title) el.title = title;
    });
    document.querySelectorAll<HTMLElement>('[data-aria-label-en]').forEach((el) => {
      const label = currentLang === 'en' ? el.dataset.ariaLabelEn : el.dataset.ariaLabelZh;
      if (label) el.setAttribute('aria-label', label);
    });
    const pageTitle = document.querySelector('title[data-title-en]');
    if (pageTitle instanceof HTMLTitleElement) {
      pageTitle.textContent = currentLang === 'en' ? pageTitle.dataset.titleEn || '' : pageTitle.dataset.titleZh || '';
    }
    document.querySelectorAll<HTMLMetaElement>('meta[data-content-en]').forEach((el) => {
      const content = currentLang === 'en' ? el.dataset.contentEn : el.dataset.contentZh;
      if (content) el.setAttribute('content', content);
    });
    window.dispatchEvent(new CustomEvent('ips:langchange', { detail: { lang: currentLang } }));
  }

  langBtn?.addEventListener('click', () => {
    currentLang = currentLang === 'en' ? 'zh' : 'en';
    localStorage.setItem('ips-lang', currentLang);
    updateLang();
  });

  updateLang();

  // Active section highlighting
  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          document.querySelectorAll('.nav-link').forEach((link) => {
            const href = link.getAttribute('href') || '';
            link.classList.toggle('active', href.endsWith(`#${entry.target.id}`));
          });
        }
      });
    },
    { rootMargin: '-20% 0px -70% 0px' },
  );

  document.querySelectorAll('section[id]').forEach((sec) => observer.observe(sec));

  // Hamburger menu toggle
  const mobileMenu = document.getElementById('nav-mobile');
  hamburger?.addEventListener('click', () => {
    hamburger.classList.toggle('open');
    mobileMenu?.classList.toggle('open');
  });
  // Close mobile menu on link click
  mobileMenu?.querySelectorAll('a').forEach((link) => {
    link.addEventListener('click', () => {
      hamburger?.classList.remove('open');
      mobileMenu?.classList.remove('open');
    });
  });
</script>
