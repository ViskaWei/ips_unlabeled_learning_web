---
interface Props {
  title?: string;
  titleZh?: string;
  description?: string;
  descriptionZh?: string;
}

const {
  title = 'Learning from Unlabeled Data for IPS',
  titleZh = '从无标签数据学习相互作用粒子系统',
  description = 'Interactive research promotion website for trajectory-free learning of particle interaction potentials',
  descriptionZh = '用于展示无轨迹相互作用粒子系统势函数学习的交互式研究网站',
} = Astro.props;

const base = import.meta.env.BASE_URL;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <script is:inline>
      try {
        const storedLang = localStorage.getItem('ips-lang');
        const preferredLang = storedLang || (navigator.language?.toLowerCase().startsWith('zh') ? 'zh' : 'en');
        document.documentElement.lang = preferredLang;
      } catch {
        document.documentElement.lang = 'en';
      }
    </script>
    <meta name="description" content={description} data-content-en={description} data-content-zh={descriptionZh} />
    <title data-title-en={title} data-title-zh={titleZh}>{title}</title>

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />

    <!-- KaTeX CSS -->
    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/katex@0.16.11/dist/katex.min.css"
      crossorigin="anonymous"
    />

    <!-- Google Scholar -->
    <meta name="citation_title" content="Learning interacting particle systems from unlabeled data" />
    <meta name="citation_author" content="Viska Wei" />
    <meta name="citation_author" content="Fei Lu" />
    <meta name="citation_date" content="2026" />
    <meta name="citation_technical_report_institution" content="Johns Hopkins University" />
    <meta name="citation_arxiv_id" content="2604.02581" />
    <meta name="citation_pdf_url" content="https://arxiv.org/pdf/2604.02581" />

    <!-- Open Graph -->
    <meta property="og:title" content={title} data-content-en={title} data-content-zh={titleZh} />
    <meta property="og:description" content={description} data-content-en={description} data-content-zh={descriptionZh} />
    <meta property="og:type" content="website" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={title} data-content-en={title} data-content-zh={titleZh} />
    <meta name="twitter:description" content={description} data-content-en={description} data-content-zh={descriptionZh} />

    <!-- Favicon -->
    <link rel="icon" href={`${base}/favicon.svg`} type="image/svg+xml" />
  </head>
  <body>
    <slot />
  </body>
</html>

<style is:global>
  @import '../styles/global.css';
</style>
